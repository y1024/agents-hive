   163	// enqueueUnsafe 将 unsafe 工具加入排队队列。
   164	// 当 unsafeCount 降为 0 时自动调度队列中的工具。
   165	func (se *StreamingExecutor) enqueueUnsafe(tool *TrackedTool) {
   166		se.mu.Lock()
   167		defer se.mu.Unlock()
   168		se.unsafeQueue = append(se.unsafeQueue, tool)
