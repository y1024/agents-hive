    30	// retryableStatusCodes 可重试的 HTTP 状态码
    31	var retryableStatusCodes = map[int]bool{
    32		429: true, // Rate Limit
    33		500: true, // Internal Server Error
    34		502: true, // Bad Gateway
    35		503: true, // Service Unavailable
