   191	
   192	func TestFilterResultsByDomain(t *testing.T) {
   193		baseResults := []SearchResult{
   194			{Title: "GitHub", URL: "https://github.com/openai", Description: "AI research"},
   195			{Title: "OpenAI", URL: "https://openai.com/research", Description: "Official site"},
   196			{Title: "Wikipedia", URL: "https://en.wikipedia.org/wiki/OpenAI", Description: "Wiki page"},
   197			{Title: "API Docs", URL: "https://api.github.com/v3", Description: "GitHub API"},
   198		}
   199	
   200		tests := []struct {
   201			name            string
   202			results         []SearchResult
   203			allowedDomains  []string
   204			blockedDomains  []string
   205			expectedCount   int
   206			expectedDomains []string
   207		}{
   208			{
   209				name:            "无过滤",
   210				results:         baseResults,
   211				allowedDomains:  nil,
   212				blockedDomains:  nil,
   213				expectedCount:   4,
   214				expectedDomains: []string{"github.com", "openai.com", "wikipedia.org", "api.github.com"},
   215			},
   216			{
   217				name:            "白名单过滤",
   218				results:         baseResults,
   219				allowedDomains:  []string{"github.com"},
   220				blockedDomains:  nil,
   221				expectedCount:   2,
   222				expectedDomains: []string{"github.com", "api.github.com"},
   223			},
   224			{
   225				name:            "黑名单过滤",
   226				results:         baseResults,
   227				allowedDomains:  nil,
   228				blockedDomains:  []string{"wikipedia.org"},
   229				expectedCount:   3,
   230				expectedDomains: []string{"github.com", "openai.com", "api.github.com"},
   231			},
   232			{
   233				name:            "白名单和黑名单同时使用",
   234				results:         baseResults,
   235				allowedDomains:  []string{"github.com"},
   236				blockedDomains:  []string{"api.github.com"},
   237				expectedCount:   1,
   238				expectedDomains: []string{"github.com"},
   239			},
   240			{
   241				name:            "空结果集",
   242				results:         []SearchResult{},
   243				allowedDomains:  []string{"github.com"},
   244				blockedDomains:  nil,
   245				expectedCount:   0,
   246				expectedDomains: []string{},
   247			},
   248		}
   249	
   250		for _, tt := range tests {
   251			t.Run(tt.name, func(t *testing.T) {
   252				filtered := filterResultsByDomain(tt.results, tt.allowedDomains, tt.blockedDomains)
   253				assert.Equal(t, tt.expectedCount, len(filtered))
   254	
   255				for i, result := range filtered {
   256					domain := strings.TrimPrefix(strings.Split(strings.TrimPrefix(result.URL, "https://"), "/")[0], "www.")
   257					if i < len(tt.expectedDomains) {
   258						assert.Contains(t, result.URL, tt.expectedDomains[i])
   259					}
   260					_ = domain // 避免未使用变量警告

