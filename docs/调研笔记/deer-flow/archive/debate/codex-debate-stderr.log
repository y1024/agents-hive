   166	// normalizeBaseURL 规范化 LLM API 的 baseURL，确保包含 /v1 路径。
   167	//
   168	// 处理逻辑：
   169	// - 空字符串 → 返回空（使用 SDK 默认）
   170	// - https://gmini.xyz → https://gmini.xyz/v1
   171	// - https://gmini.xyz/ → https://gmini.xyz/v1
   172	// - https://gmini.xyz/v1 → 保持不变
   173	// - http://localhost:8080 → http://localhost:8080/v1
   174	// - https://api.custom.com/custom/path → 保持不变（自定义路径）
   175	func normalizeBaseURL(baseURL string) string {
   176		if baseURL == "" {
   177			return ""
   178		}
   179	
   180		u, err := url.Parse(baseURL)
   181		if err != nil {
   182			// 无效 URL，让 SDK 处理错误
   183			return baseURL
   184		}
   185	
   186		// 如果没有 scheme（http/https），说明不是有效的 URL，保持原样
   187		if u.Scheme == "" {
   188			return baseURL
   189		}
   190	
   191		// 路径为空或仅为 /，添加 /v1
   192		if u.Path == "" || u.Path == "/" {
   193			u.Path = "/v1"
   194			return u.String()
   195		}
   196	
   197		// 检查是否已有 /v1 后缀（忽略大小写）
   198		pathLower := strings.ToLower(u.Path)
   199		if strings.HasSuffix(pathLower, "/v1") || strings.HasSuffix(pathLower, "/v1/") {
   200			// 已经有 /v1 后缀，保持不变
   201			return baseURL
   202		}
   203	
   204		// 仅对简单路径（1个段或更少）自动添加 /v1
   205		// 复杂路径（如 /custom/endpoint）视为用户有意为之
   206		segments := strings.Split(strings.Trim(u.Path, "/"), "/")
   207		if len(segments) <= 1 {
   208			u.Path = strings.TrimSuffix(u.Path, "/") + "/v1"
   209			return u.String()
   210		}
   211	
   212		// 复杂自定义路径，保持不变
   213		return baseURL
   214	}
