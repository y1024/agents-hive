    42	// maxResultsHardCap 是 websearch 参数的硬上限。
    43	// 与 parseSearchResults 内部的 50 条 break 上限保持一致，防止客户端传 10000 这种
    44	// 导致下游 O(n) 遍历退化。
    45	const maxResultsHardCap = 50
    46	
    47	// clampMaxResults 实现 websearch 的 MaxResults 归一化：
    48	//   - 0 (未传或显式 0) → 10（文档默认值，跟前端 UI 一致）
    49	//   - >50 → 50（硬上限）
    50	//   - 其它 → 原样
    51	//
    52	// 拆为纯函数是为了可独立单测 L112 的参数上限逻辑。之前这段内联在 handler 里，
    53	// 测试不得不叠加 rawCount 去触发；但 parseSearchResults 自身有 50 条 break，
    54	// 导致 MaxResults=100 vs MaxResults=50 在下游切片点无可观测差异，clamp 分支成了
    55	// 测试空白。现在直接 clampMaxResults(100) 即可 assert 返回 50。
    56	func clampMaxResults(raw int) int {
    57		if raw == 0 {
    58			return 10
    59		}
    60		if raw > maxResultsHardCap {
    61			return maxResultsHardCap
    62		}
    63		return raw
    64	}
