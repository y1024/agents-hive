   164		if tc, ok := buildResponsesToolChoice(req.ToolChoice); ok {
   165			params.ToolChoice = tc
   166		}
   167	
   168		// 推理努力级别：单次请求覆盖 > 客户端默认值
   169		effort := c.reasoningEffort
   170		if req.ReasoningEffort != "" {
   171			effort = req.ReasoningEffort
   172		}
   173		if effort != "" {
   174			params.Reasoning = shared.ReasoningParam{
   175				Effort: shared.ReasoningEffort(effort),
   176			}
   177		}
   178	
   179		// 调用 API（带重试）
   180		resp, err := retryableAPICall(ctx, c.logger, "responses_chat_with_tools", func() (*responses.Response, error) {
   181			return c.client.Responses.New(ctx, params)
   182		})
   183		if err != nil {
   184			c.logAPIError(err, "responses_chat_with_tools")
   185			return nil, errs.Wrap(errs.CodeLLMError, "Responses API 调用失败", err)
   186		}
   187	
   188		// 解析响应
   189		result := &ChatWithToolsResponse{
   190			Content:      resp.OutputText(),
   191			FinishReason: extractResponsesFinishReason(resp),
   192			Usage:        convertResponsesUsage(resp),
   193		}
   194	
   195		// 提取工具调用
   196		for _, item := range resp.Output {
   197			if item.Type == "function_call" {
   198				result.ToolCalls = append(result.ToolCalls, ToolCall{
   199					ID:        item.CallID,
   200					Name:      item.Name,
   201					Arguments: json.RawMessage(item.Arguments),
   202				})
   203			}
   204		}
   205	
   206		// 提取 reasoning content
   207		for _, item := range resp.Output {
   208			if item.Type == "reasoning" {
   209				for _, s := range item.Summary {
   210					if s.Text != "" {
   211						if result.ReasoningContent != "" {
