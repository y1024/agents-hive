   220		c.logger.Debug("Responses API 调用完成",
   221			zap.String("model", snapModel),
   222			zap.Int("tool_calls", len(result.ToolCalls)),
   223			zap.Int64("prompt_tokens", result.Usage.PromptTokens),
   224			zap.Int64("completion_tokens", result.Usage.CompletionTokens),
   225		)
   226	
   227		return result, nil
   228	}
