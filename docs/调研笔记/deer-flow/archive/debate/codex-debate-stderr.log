   150	// markJSONModeUnsupported 标记当前 API 端点不支持 JSON mode。
   151	//
   152	// 副作用：
   153	// - 更新包级缓存 unsupportedJSONModeCache
   154	// - 记录 Info 级别日志
   155	func (c *Client) markJSONModeUnsupported() {
   156		if c.baseURL == "" {
   157			return
   158		}
   159	
   160		unsupportedJSONModeCache.Store(c.baseURL, time.Now())
   161		c.logger.Info("检测到 API 端点不支持 JSON mode，后续请求将自动跳过",
   162			zap.String("base_url", c.baseURL),
   163		)
   164	}
