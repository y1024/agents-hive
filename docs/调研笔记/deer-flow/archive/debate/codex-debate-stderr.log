   981	// executeTool 执行单个工具调用，返回结果
   982	func (m *Master) executeTool(ctx context.Context, sessionID, userID string, toolCall llm.ToolCall, sessionTraceID, sessionSpanID string) toolResult {
   983		// 统一注入 sessionID，确保下游工具（如 spawn_agent）能从 ctx 中提取
   984		ctx = toolctx.WithSessionID(ctx, sessionID)
   985	
   986		// 广播工具调用开始事件
   987		m.emitToolCallEvent(sessionID, ToolCallEvent{
   988			ToolCallID: toolCall.ID,
   989			ToolName:   toolCall.Name,
   990			Status:     "start",
   991			SessionID:  sessionID,
   992		})
   993	
   994		// 检查 HITL 批准时是否有参数覆盖（如用户在审批卡片中更改了 theme_id）
   995		args := toolCall.Arguments
   996		overrideKey := sessionID + ":" + toolCall.Name
   997		if override, ok := m.toolArgOverrides.LoadAndDelete(overrideKey); ok {
   998			args = override.(json.RawMessage)
   999		}
  1000	
  1001		// wenyan publish_article 防御：LLM 经常忘记在 content 中加 frontmatter title，
  1002		// 导致 MCP 报 "未能找到文章标题"。自动检测并注入。
  1003		if toolCall.Name == "wenyan__publish_article" {
  1004			args = ensureWenyanTitle(args, m.logger)
  1005		}
  1006	
  1007		// 工具策略过滤检查：确保 LLM 不会调用被 profile/deny 排除的工具
  1008		if m.masterFilter != nil && !m.masterFilter.IsAllowed(toolCall.Name) {
  1009			m.logger.Info("工具被策略过滤拒绝",
  1010				zap.String("tool", toolCall.Name))
  1011			m.emitToolCallEvent(sessionID, ToolCallEvent{
  1012				ToolCallID: toolCall.ID,
  1013				ToolName:   toolCall.Name,
  1014				Status:     "error",
  1015				Error:      fmt.Sprintf("tool %q is not allowed by tool policy", toolCall.Name),
  1016				SessionID:  sessionID,
  1017			})
  1018			m.logToolCall(ctx, sessionID, toolCall, "", fmt.Sprintf("[工具策略拒绝: %q 不在当前 profile 的允许列表中]", toolCall.Name), true, 0)
  1019			return toolResult{Content: fmt.Sprintf("[工具策略拒绝: %q 不在当前 profile 的允许列表中]", toolCall.Name), IsError: true, Terminal: true}
  1020		}
  1021	
  1022		// 权限检查：仅在 HITL 启用且配置了 permMgr 时进行，否则直接执行
  1023		// 如果 context 中标记了 SkipPermission（同任务内已审批过的 tool+args 组合），跳过权限检查
  1024		if m.permMgr != nil && m.hitlBroker != nil && m.hitlBroker.Enabled() && !toolctx.ShouldSkipPermission(ctx) {
  1025			ctxWithSession := toolctx.WithSessionID(ctx, sessionID)
  1026			if err := m.permMgr.CheckPermission(ctxWithSession, toolCall.Name, args); err != nil {
  1027				m.logger.Info("工具执行被拒绝",
  1028					zap.String("tool", toolCall.Name),
  1029					zap.Error(err))
  1030				m.emitToolCallEvent(sessionID, ToolCallEvent{
  1031					ToolCallID: toolCall.ID,
  1032					ToolName:   toolCall.Name,
  1033					Status:     "error",
  1034					Error:      err.Error(),
  1035					SessionID:  sessionID,
  1036				})
  1037				m.logToolCall(ctx, sessionID, toolCall, "", fmt.Sprintf("[权限拒绝: %v]", err), true, 0)
  1038				return toolResult{Content: fmt.Sprintf("[权限拒绝: %v]", err), IsError: true, Terminal: true}
  1039			}
  1040		}

