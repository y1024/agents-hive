    82	// isResponseFormatError 检测错误是否由不支持的 response_format 参数引起。
    83	//
    84	// 检测标准：
    85	// 1. HTTP 状态码为 400（Bad Request）
    86	// 2. 错误消息包含 "response_format" 关键词，或包含中文"不合法"/"unsupported"
    87	//
    88	// 适用场景：
    89	// - OpenAI 兼容 API 不支持 response_format 参数
    90	// - 例如 gmini.xyz、DeepSeek 等第三方 API
    91	func isResponseFormatError(err error) bool {
    92		var apiErr *openai.Error
    93		if !errors.As(err, &apiErr) {
    94			return false
    95		}
    96	
    97		// 必须是 400 错误
    98		if apiErr.StatusCode != 400 {
    99			return false
   100		}
   101	
   102		// 检查错误消息关键词（支持中英文）
   103		msg := strings.ToLower(apiErr.Message)
   104	
   105		// 必须包含 response_format，或包含明确的中文/英文不支持提示
   106		if strings.Contains(msg, "response_format") {
   107			return true
   108		}
   109	
   110		// 中文错误："不合法的response_format"
   111		if strings.Contains(msg, "不合法") && strings.Contains(msg, "response") {
   112			return true
   113		}
   114	
   115		// 英文错误："unsupported response_format"
   116		if strings.Contains(msg, "unsupported") && strings.Contains(msg, "response") {
   117			return true
   118		}
   119	
   120		return false
   121	}
