   210	func (c *searchClient) performSearch(ctx context.Context, query string, logger *zap.Logger) ([]SearchResult, error) {
   211		if c.HTTPClient == nil {
   212			return nil, errs.New(errs.CodeMCPConnFailed, "searchClient 未设置 HTTPClient")
   213		}
   214		endpoint := c.Endpoint
   215		if endpoint == "" {
   216			endpoint = "https://html.duckduckgo.com/html/"
   217		}
   218		searchURL := endpoint
   219		if strings.Contains(endpoint, "?") {
   220			searchURL = endpoint + "&q=" + url.QueryEscape(query)
   221		} else {
   222			searchURL = endpoint + "?q=" + url.QueryEscape(query)
   223		}
   224	
   225		req, err := http.NewRequestWithContext(ctx, "GET", searchURL, nil)
   226		if err != nil {
   227			return nil, errs.Wrap(errs.CodeMCPConnFailed, "创建请求失败", err)
   228		}
   229		req.Header.Set("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36")
   230	
   231		resp, err := c.HTTPClient.Do(req)
   232		if err != nil {
   233			return nil, errs.Wrap(errs.CodeMCPConnFailed, "HTTP 请求失败", err)
   234		}
   235		defer resp.Body.Close()
   236	
   237		if resp.StatusCode != http.StatusOK {
   238			return nil, errs.New(errs.CodeMCPConnFailed, fmt.Sprintf("搜索服务返回错误: HTTP %d", resp.StatusCode))
   239		}
   240	
   241		body, err := io.ReadAll(io.LimitReader(resp.Body, 10*1024*1024))
   242		if err != nil {
   243			return nil, errs.Wrap(errs.CodeMCPConnFailed, "读取响应失败", err)
   244		}
   245	
   246		return parseSearchResults(string(body), logger), nil
   247	}
