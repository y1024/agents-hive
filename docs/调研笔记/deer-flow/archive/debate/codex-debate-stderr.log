    38	// isRetryableError 判断错误是否为可重试的 LLM API 错误。
    39	// 对 429、500、502、503 返回 true；对 400、401、403 等客户端错误返回 false。
    40	// 同时检查 errs.Error 的 Retryable 标记，以支持流式重试场景中被包装的错误。
    41	func isRetryableError(err error) bool {
    42		if errs.IsRetryable(err) {
    43			return true
    44		}
    45		var apiErr *openai.Error
    46		if !errors.As(err, &apiErr) {
    47			return false
    48		}
    49		return retryableStatusCodes[apiErr.StatusCode]
    50	}
    51	
    52	// llmRetryPolicy 是 LLM API 调用的默认重试策略。
    53	var llmRetryPolicy = &resilience.ExponentialBackoff{
    54		MaxAttempts:  3,
    55		BaseDelay:    1 * time.Second,
    56		MaxDelay:     30 * time.Second,
    57		MaxJitterPct: 0.3,
    58		IsRetryable:  isRetryableError,
    59	}
