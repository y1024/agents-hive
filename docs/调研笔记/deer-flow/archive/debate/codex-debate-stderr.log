     9	// SubscribeWSBroadcast 创建一个 WebSocket 广播订阅（委托给 EventBus）
    10	func (m *Master) SubscribeWSBroadcast() (uint64, chan BroadcastMessage) {
    11		return m.eventBus.Subscribe()
    12	}
    13	
    14	// UnsubscribeWSBroadcast 取消 WebSocket 广播订阅（委托给 EventBus）
    15	func (m *Master) UnsubscribeWSBroadcast(subID uint64) {
    16		m.eventBus.Unsubscribe(subID)
    17	}
    18	
    19	// broadcast 向所有订阅者广播消息（委托给 EventBus）
    20	func (m *Master) broadcast(msg BroadcastMessage) {
    21		m.eventBus.Broadcast(msg)
    22	}
    23	
    24	// BroadcastInputRequest 广播 input_request 消息（委托给 EventBus）
    25	func (m *Master) BroadcastInputRequest(req *InputRequest) {
    26		m.eventBus.BroadcastInputRequest(req)
    27	}
    28	
    29	// SubscribeInputResponse 订阅指定 reqID 的 InputResponse。
    30	//
    31	// 返回一个容量 1 的只读通道：收到匹配的响应后发送并关闭；ctx 取消或 EventBus
    32	// 关闭时也会关闭（不发送值）。调用方必须总是 <-ch 读到 ok=false 才能确认清理完成。
    33	//
    34	// 设计：挂在 *Master 与 BroadcastInputRequest 同位置，业务 Skill/Tool 不直接
    35	// 感知 EventBus。goroutine 在所有退出路径（匹配 / ctx / eventbus close）都会
    36	// 调用 Unsubscribe，确保零泄漏（goleak 验证）。
    37	func (m *Master) SubscribeInputResponse(ctx context.Context, reqID string) <-chan *InputResponse {
    38		out := make(chan *InputResponse, 1)
    39		subID, sub := m.eventBus.Subscribe()
    40		if sub == nil {
    41			close(out)
    42			return out
    43		}
    44		go func() {
    45			defer m.eventBus.Unsubscribe(subID)
    46			defer close(out)
    47			for {
    48				select {
    49				case <-ctx.Done():
    50					return
    51				case msg, ok := <-sub:
    52					if !ok {
    53						return
    54					}
    55					if msg.Type != EventTypeInputResponse {
    56						continue
    57					}
    58					resp, ok := msg.Payload.(*InputResponse)
    59					if !ok || resp == nil || resp.RequestID != reqID {
    60						continue
    61					}
    62					out <- resp
    63					return
    64				}
    65			}
    66		}()
    67		return out
    68	}
    69	
    70	// BroadcastGenericMessage 广播通用消息（委托给 EventBus）
    71	func (m *Master) BroadcastGenericMessage(msgType string, payload interface{}) {
    72		m.eventBus.BroadcastGenericMessage(msgType, payload)
    73	}
    74	
    75	// BroadcastTaskGroup 实现 tools.ParallelDispatchBroadcaster 接口 — 广播任务组生命周期事件
    76	func (m *Master) BroadcastTaskGroup(groupID string, status string, total int, tasks interface{}, results interface{}) {
    77		completed := 0
    78		if briefs, ok := tasks.([]interface{}); ok {
    79			for _, b := range briefs {
    80				if bm, ok := b.(map[string]string); ok && bm["status"] == "completed" {
    81					completed++
    82				}
    83			}
    84		}
    85		m.broadcast(BroadcastMessage{
    86			Type: EventTypeTaskGroup,
    87			Payload: TaskGroupEvent{
    88				GroupID:   groupID,
    89				Status:    status,
    90				Total:     total,
    91				Completed: completed,
    92				Results:   results,
    93			},
    94		})
    95	}
    96	
    97	// BroadcastTaskProgress 实现 tools.ParallelDispatchBroadcaster 接口 — 广播单个任务进度事件
    98	func (m *Master) BroadcastTaskProgress(groupID string, taskID string, status string, errMsg string) {
    99		m.broadcast(BroadcastMessage{
   100			Type: EventTypeTaskProgress,
   101			Payload: map[string]string{
   102				"group_id": groupID,
   103				"task_id":  taskID,
   104				"status":   status,
   105				"error":    errMsg,
   106			},
   107		})
   108		// 触发 TaskCreated / TaskCompleted hook（非阻塞）
   109		if m.pluginMgr != nil {
   110			input := &plugin.TaskEventInput{
   111				TaskID:  taskID,
   112				Status:  status,
   113				Error:   errMsg,
   114			}
   115			go func() {
   116				hookCtx, cancel := context.WithTimeout(context.Background(), plugin.HookCallTimeout)
   117				defer cancel()
   118				switch status {
   119				case "pending", "running":
   120					_ = m.pluginMgr.TriggerTaskCreated(hookCtx, input)
   121				case "completed", "failed":
   122					_ = m.pluginMgr.TriggerTaskCompleted(hookCtx, input)
   123				}
   124			}()
   125		}
   126	}

