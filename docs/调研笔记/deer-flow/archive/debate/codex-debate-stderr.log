   185	// AbortAll 取消所有 pending 工具（bash 失败时调用）。
   186	func (se *StreamingExecutor) AbortAll(reason string) {
   187		se.mu.Lock()
   188		defer se.mu.Unlock()
   189	
   190		for _, tool := range se.pending {
   191			if !tool.IsSafe {
   192				tool.Aborted = true
