   176	// Run 执行 agent 循环,返回最终文本响应
   177	func (a *AgentLoop) Run(ctx context.Context, systemPrompt string, messages []llm.MessageWithTools, filter *skills.ToolFilter) (string, error) {
   178		tools := a.toolBridge.AvailableTools(filter)
   179	
   180		// 注意：ToolContext 功能已移除，直接执行循环
   181	
   182		for turn := 0; turn < a.maxTurns; turn++ {
   183			// 检查 context 是否已取消
   184			if ctx.Err() != nil {
   185				a.logger.Info("SubAgent 被取消", zap.String("agent", a.agentID), zap.Error(ctx.Err()))
   186				return "", errs.Wrap(errs.CodeCanceled, "agent 循环已取消", ctx.Err())
   187			}
   188	
   189			// 每次轮次开始时动态获取 LLM client（支持 session 模型切换和 task-type 选路）
   190			llmClient := a.resolveLLMClient()
   191			if llmClient == nil {
   192				return "", errs.New(errs.CodeLLMError, "无可用 LLM 客户端")
   193			}
   194	
   195			a.logger.Info("SubAgent 轮次开始",
   196				zap.String("agent", a.agentID),
   197				zap.Int("turn", turn+1),
   198				zap.Int("max_turns", a.maxTurns),
   199				zap.Int("tool_count", len(tools)),
   200			)
   201	
   202			llmStart := time.Now()
   203			resp, err := llmClient.ChatWithToolsStream(ctx, llm.ChatWithToolsRequest{
   204				SystemPrompt: systemPrompt,
   205				Messages:     messages,
   206				Tools:        tools,
   207				Temperature:  0.1,
   208				MaxTokens:    4096,
   209			}, func(chunk llm.StreamChunk) error {
   210				if chunk.Done {
   211					return nil
   212				}
   213				if a.streamFn != nil && (chunk.ContentSoFar != "" || chunk.ReasoningContent != "") {
   214					a.streamFn(a.agentID, a.sessionID, chunk.ContentSoFar, chunk.ReasoningContent)
   215				}
   216				return nil
   217			})
   218			if err != nil {
   219				// 区分 context 取消和真正的 LLM 错误
   220				if ctx.Err() != nil {
   221					return "", errs.Wrap(errs.CodeCanceled, fmt.Sprintf("SubAgent %s 调用期间被取消", a.agentID), err)
   222				}
   223				return "", errs.Wrap(errs.CodeLLMError, fmt.Sprintf("SubAgent %s LLM 调用失败", a.agentID), err)
   224			}
   225	
   226			a.logger.Info("SubAgent LLM 调用完成",
   227				zap.String("agent", a.agentID),
   228				zap.Int("turn", turn+1),
   229				zap.Duration("duration", time.Since(llmStart)),
   230				zap.String("finish_reason", resp.FinishReason),
   231				zap.Int("tool_calls", len(resp.ToolCalls)),
   232				zap.Int64("prompt_tokens", resp.Usage.PromptTokens),
   233				zap.Int64("completion_tokens", resp.Usage.CompletionTokens),
   234			)
   235	
   236			// 成本追踪回调（nil 安全）
   237			if a.llmCompleteFn != nil && (resp.Usage.PromptTokens > 0 || resp.Usage.CompletionTokens > 0) {
   238				model := ""
   239				if c, ok := llmClient.(*llm.Client); ok {
   240					model = c.Model()
   241				}
   242				a.llmCompleteFn(a.agentID, a.sessionID, a.userID, model, resp.Usage)
   243			}
   244	
   245			// 无 tool calls - 返回文本
   246			if len(resp.ToolCalls) == 0 {
   247				a.logger.Info("SubAgent 循环完成",
   248					zap.String("agent", a.agentID),
   249					zap.Int("turns_used", turn+1),
   250				)
   251				return resp.Content, nil
   252			}
   253	
   254			// 将 assistant 的 tool calls 添加到消息历史
   255			messages = append(messages, llm.MessageWithTools{
   256				Role:      "assistant",
   257				Content:   llm.NewTextContent(resp.Content),
   258				ToolCalls: resp.ToolCalls,
   259			})
