    60		ListSummaries(userID ...string) []skills.SkillSummary
    61		Get(name string, userID ...string) (*skills.Skill, error)
    62		GetForkHandler() skills.ForkHandler
    63		InvokeFull(ctx context.Context, name string, rctx skills.RenderContext, executor skills.ShellExecutor, runner *skills.ScriptRunner, hookRunner *skills.HookRunner) (string, error)
    64	}
    65	
    66	// skillSelfHealDiscovery 是 on_demand 自愈路径所需的最小 Discovery 接口。
    67	// nil → 自愈禁用（等价 pre-change 行为，§8.4 契约保证 byte-identical）。
    68	type skillSelfHealDiscovery interface {
    69		ResolveByName(ctx context.Context, name string, refresh bool) (*skills.ResolvedSkill, error)
    70	}
    71	
    72	// registerSkill 注册 skill 工具到 MCP host（旧签名，自愈禁用）
    73	func registerSkill(host *mcphost.Host, logger *zap.Logger, skillReg skillRegistry) {
    74		registerSkillWithSelfHeal(host, logger, skillReg, nil)
    75	}
    76	
    77	// registerSkillWithSelfHeal 注册 skill 工具；当 discovery 非 nil 时，Get 失败会
    78	// 触发 on-demand 自愈提示（tasks.md §8）。
    79	func registerSkillWithSelfHeal(host *mcphost.Host, logger *zap.Logger, skillReg skillRegistry, discovery skillSelfHealDiscovery) {
    80		// Schema with name (optional) and arguments (optional)
    81		schema, _ := json.Marshal(map[string]any{
    82			"type": "object",
    83			"properties": map[string]any{
    84				"name": map[string]any{
    85					"type":        "string",
    86					"description": "要调用的技能名称。为空时列出所有可用技能",
    87				},
    88				"arguments": map[string]any{
    89					"type":        "string",
    90					"description": "传递给技能的参数（可选）",
    91				},
    92			},
    93		})
    94	
    95		host.RegisterTool(
    96			mcphost.ToolDefinition{
    97				Name:        "skill",
    98				Description: "调用或列出可用技能。不传 name 参数时列出所有技能摘要，传入 name 时调用指定技能",
    99				InputSchema: schema,
   100			},
   101			func(ctx context.Context, input json.RawMessage) (*mcphost.ToolResult, error) {
   102				var params skillInput
   103				if err := json.Unmarshal(input, &params); err != nil {
   104					return errorResult("输入无效: " + err.Error()), nil
   105				}
   106	
   107				userID := auth.UserIDFrom(ctx)
   108	
   109				// 如果 name 为空，列出所有技能
   110				if params.Name == "" {
   111					var summaries []skills.SkillSummary
   112					if userID != "" {
   113						summaries = skillReg.ListSummaries(userID)
   114					} else {
   115						summaries = skillReg.ListSummaries()
   116					}
   117					if len(summaries) == 0 {
   118						return textResult("没有可用的技能"), nil
   119					}
   120					data, err := json.Marshal(summaries)
   121					if err != nil {
   122						return errorResult("序列化技能列表失败: " + err.Error()), nil
   123					}
   124					return textResult(string(data)), nil
   125				}
   126	
   127				// 调用指定技能（走完整管道：hooks + 动态上下文 + 脚本）
   128				rctx := skills.RenderContext{
   129					Arguments: params.Arguments,
   130				}
   131				executor := &skills.DefaultShellExecutor{
   132					Timeout:  600 * time.Second,
   133					Executor: sandboxToSkillsAdapter(),
   134				}
   135	
   136				// 检查是否为 context=fork 类型（需要隔离的 sub-agent 执行）
   137				var s *skills.Skill
   138				var err error
   139				if userID != "" {
   140					s, err = skillReg.Get(params.Name, userID)
   141				} else {
   142					s, err = skillReg.Get(params.Name)
   143				}
   144				if err != nil {
   145					// §8 自愈路径：Discovery 非 nil 时尝试解析 marketplace，命中则附加
   146					// suggested_action；保留原始错误字符串（§8.3 向后兼容）
   147					return skillGetErrorWithSelfHeal(ctx, discovery, params.Name, err), nil
   148				}
   149				if s.Metadata.Context == "fork" {
   150					forkHandler := skillReg.GetForkHandler()
   151					if forkHandler == nil {
   152						return errorResult(fmt.Sprintf("技能 %q 需要 fork 执行但 ForkHandler 未配置", params.Name)), nil
   153					}
   154					result, err := forkHandler.ExecuteForked(ctx, s, rctx, executor)
   155					if err != nil {
   156						return errorResult(fmt.Sprintf("fork 执行技能 %q 失败: %v", params.Name, err)), nil
   157					}
   158					return textResult(result), nil
   159				}
   160	
   161				runner := skills.NewScriptRunner(30*time.Second, logger)
   162				runner.Executor = sandboxToSkillsAdapter()
   163				hookRunner := skills.NewHookRunner(executor, logger)
   164	
   165				result, err := skillReg.InvokeFull(ctx, params.Name, rctx, executor, runner, hookRunner)
   166				if err != nil {
   167					return errorResult(fmt.Sprintf("调用技能 %q 失败: %v", params.Name, err)), nil
   168				}
   169	
   170				return textResult(result), nil
   171			},
   172		)
   173	
   174		logger.Info("已注册 skill 工具")
   175	}
   176	
   177	// skillGetErrorWithSelfHeal 在 skill Get 失败时，按 §8 自愈契约返回结果：
   178	//   - discovery == nil → 原始错误字符串（§8.4 byte-identical baseline）
   179	//   - discovery 非 nil 且 ResolveByName 命中 → 在 ToolResult 中追加 suggested_action
   180	//     （§8.3 保留原始 error 字段内容不变，仅扩展 payload）
   181	//   - discovery 非 nil 但未命中 → 原始错误字符串
   182	func skillGetErrorWithSelfHeal(ctx context.Context, discovery skillSelfHealDiscovery, name string, origErr error) *mcphost.ToolResult {
   183		origMsg := fmt.Sprintf("获取技能 %q 失败: %v", name, origErr)
   184		if discovery == nil {
   185			return errorResult(origMsg)
   186		}
   187		resolved, rerr := discovery.ResolveByName(ctx, name, false)
   188		if rerr != nil || resolved == nil {
   189			return errorResult(origMsg)
   190		}
   191		payload, err := json.Marshal(map[string]any{
   192			"error": origMsg,
   193			"suggested_action": map[string]any{
   194				"tool": "skill_install",
   195				"args": map[string]any{
   196					"name":   name,
   197					"scope":  "personal",
   198					"source": resolved.Source,
   199				},
   200				"reason": fmt.Sprintf("skill %q 未在本地注册，可通过 skill_install 从 marketplace 安装", name),
   201			},
   202		})
   203		if err != nil {
   204			return errorResult(origMsg)
   205		}
   206		return &mcphost.ToolResult{Content: jsonText(string(payload)), IsError: true}
   207	}
   208	
   209	// registerSkillFromInterface 通过 interface{} 参数注册 skill 工具
   210	// 避免 tools.go 直接导入 skills 包（防止 goimports 移除）
   211	func registerSkillFromInterface(host *mcphost.Host, logger *zap.Logger, skillRegI interface{}) {
   212		if sr, ok := skillRegI.(*skills.OverlayRegistry); ok && sr != nil {
   213			registerSkill(host, logger, sr)
   214		} else if sr, ok := skillRegI.(*skills.Registry); ok && sr != nil {
   215			registerSkill(host, logger, sr)
   216		}
   217	}
