  1844	// executeToolsConcurrent 使用 StreamingExecutor 并发执行工具。
  1845	// safe 工具（IsConcurrencySafe=true）并发执行，unsafe 工具按原始顺序串行。
  1846	// 维护与串行路径相同的状态：terminalCache, approvedCalls, terminalFailures。
  1847	// 注意：调用级循环检测（detector.recordCallResult）在此路径中不执行，属于已知的初始版本限制。
  1848	func (m *Master) executeToolsConcurrent(
  1849		ctx context.Context,
  1850		session *SessionState,
  1851		userID string,
  1852		toolCalls []llm.ToolCall,
  1853		rejectedIDs map[string]bool,
  1854		terminalCache map[string]string,
  1855		approvedCalls map[string]bool,
  1856		terminalFailures *[]string,
  1857		sessionTraceID, sessionSpanID string,
  1858	) {
  1859		// 1. 过滤 rejected 和 terminalCache，与串行路径逻辑一致
  1860		type pendingCall struct {
  1861			tc      llm.ToolCall
  1862			toolCtx context.Context
  1863		}
  1864		var toExecute []pendingCall
  1865	
  1866		for _, toolCall := range toolCalls {
  1867			if rejectedIDs[toolCall.ID] {
  1868				errContent := fmt.Sprintf("错误：单轮最多 3 个 spawn_agent 调用，请减少并发或分批执行")
  1869				toolCreatedAt := time.Now().Format(time.RFC3339)
  1870				m.appendSessionMessage(session, llm.MessageWithTools{
  1871					Role:       "tool",
  1872					ToolCallID: toolCall.ID,
  1873					Content:    llm.NewTextContent(errContent),
  1874					IsError:    true,
  1875					ToolName:   toolCall.Name,
  1876					CreatedAt:  toolCreatedAt,
  1877					Metadata:   map[string]string{"agent_id": "master"},
  1878				})
  1879				m.broadcastToolMessage(session.ID, toolCall.ID, toolCall.Name, errContent, toolCreatedAt, true)
  1880				continue
  1881			}
  1882	
  1883			callFP := canonicalFingerprint(toolCall.Name, toolCall.Arguments)
  1884			if cachedErr, hit := terminalCache[callFP]; hit {
  1885				toolCreatedAt := time.Now().Format(time.RFC3339)
  1886				m.appendSessionMessage(session, llm.MessageWithTools{
  1887					Role:       "tool",
  1888					ToolCallID: toolCall.ID,
  1889					Content:    llm.NewTextContent(cachedErr),
  1890					IsError:    true,
  1891					ToolName:   toolCall.Name,
  1892					CreatedAt:  toolCreatedAt,
  1893					Metadata:   map[string]string{"agent_id": "master"},
  1894				})
  1895				m.broadcastToolMessage(session.ID, toolCall.ID, toolCall.Name, cachedErr, toolCreatedAt, true)
  1896				*terminalFailures = append(*terminalFailures, toolCall.Name)
  1897				continue
  1898			}
  1899	
  1900			toolCtx := ctx
  1901			if approvedCalls[callFP] {
  1902				toolCtx = toolctx.WithSkipPermission(ctx)
  1903			}
  1904			toExecute = append(toExecute, pendingCall{tc: toolCall, toolCtx: toolCtx})
  1905		}
  1906	
  1907		if len(toExecute) == 0 {
  1908			return
  1909		}
  1910	
  1911		// 2. 构建 id -> pendingCall 映射，供 executor 闭包按 ID 回查
  1912		callByID := make(map[string]pendingCall, len(toExecute))
  1913		for _, p := range toExecute {
  1914			callByID[p.tc.ID] = p
  1915		}
  1916	
  1917		// 3. 获取工具定义列表（与 prepareDirectExecParams 路径一致）
  1918		var availableTools []mcphost.ToolDefinition
  1919		if m.toolBridge != nil {
  1920			availableTools = m.toolBridge.AvailableTools(m.masterFilter)
  1921		} else if m.mcpHost != nil {
  1922			availableTools = m.mcpHost.ListTools()
  1923		}
  1924	
  1925		// 4. 创建 batch 级可取消 context（SiblingAbortController：任一工具失败时取消其余工具）
  1926		batchCtx, batchCancel := context.WithCancel(ctx)
  1927		defer batchCancel()
  1928	
  1929		// 4b. 创建 StreamingExecutor
  1930		// executor 通过 tool call ID（即 AddTool 的第一个参数）回查 pendingCall。
  1931		// 由于 ToolExecutorFunc 签名为 (ctx, name, input)，不携带 ID，
  1932		// 我们利用 StreamingExecutor 传入的 id 字段在 TrackedTool 中存储，
  1933		// 但 executor 函数无法直接获取 ID。
  1934		// 解决方案：用 canonicalFingerprint(name, input) 作为查找 key，
  1935		// 因为同一轮 LLM 调用中相同 name+args 的 toolCtx 一致（均经过 approvedCalls 检查）。
  1936		se := NewStreamingExecutor(
  1937			availableTools,
  1938			func(execCtx context.Context, name string, input json.RawMessage) (*mcphost.ToolResult, error) {
  1939				fp := canonicalFingerprint(name, input)
  1940				// 按 fingerprint 找到最先匹配的 pendingCall（顺序无关，toolCtx 一致）
  1941				var resolvedCtx context.Context
  1942				for _, p := range callByID {
  1943					if canonicalFingerprint(p.tc.Name, p.tc.Arguments) == fp {
  1944						resolvedCtx = p.toolCtx
  1945						break
  1946					}
  1947				}
  1948				if resolvedCtx == nil {
  1949					resolvedCtx = execCtx
  1950				}
  1951	
  1952				// 构建 ToolCall（executeTool 需要完整字段）
  1953				tc := llm.ToolCall{Name: name, Arguments: input}
  1954				tr := m.executeTool(resolvedCtx, session.ID, userID, tc, sessionTraceID, sessionSpanID)
  1955	
  1956				// 将 string content 编码为 json.RawMessage
  1957				contentBytes, _ := json.Marshal(tr.Content)
  1958				return &mcphost.ToolResult{Content: contentBytes, IsError: tr.IsError}, nil
  1959			},
  1960		)
  1961	
  1962		// 4c. 注册 emitFunc：当任一工具失败时取消 batchCtx，终止其余正在执行的工具
  1963		se.SetEmitFunc(func(result *mcphost.ToolResult) {
  1964			if result != nil && result.IsError {
  1965				batchCancel()
  1966			}
  1967		})
  1968	
  1969		// 5. 按原始顺序添加工具（传入 batchCtx，失败时可通过 batchCancel 传播取消）
  1970		for _, p := range toExecute {
  1971			se.AddTool(batchCtx, p.tc.ID, p.tc.Name, p.tc.Arguments)
  1972		}
  1973	
  1974		// 6. 等待所有工具完成，获取以 ID 为键的结果 map（Bug 2 fix: 避免 index 对齐错误）
  1975		resultsByID := se.GetResultsByID()
  1976	
  1977		// 7. 按原始顺序处理结果，通过工具 ID 精确查找对应结果
  1978		for _, p := range toExecute {
  1979			toolCall := p.tc
  1980			r, ok := resultsByID[toolCall.ID]
  1981			if !ok {
  1982				// 工具被 abort 或未产生结果，跳过
  1983				continue
  1984			}
  1985	
  1986			// 解码结果内容（executor 闭包中用 json.Marshal(string) 编码）
  1987			contentStr := r.DecodeContent()
  1988			isError := r.IsError
  1989	
  1990			toolCreatedAt := time.Now().Format(time.RFC3339)
  1991			m.appendSessionMessage(session, llm.MessageWithTools{
  1992				Role:       "tool",
  1993				ToolCallID: toolCall.ID,
  1994				Content:    llm.NewTextContent(contentStr),
  1995				IsError:    isError,
  1996				ToolName:   toolCall.Name,
  1997				CreatedAt:  toolCreatedAt,
  1998				Metadata:   map[string]string{"agent_id": "master"},
  1999			})
  2000			m.broadcastToolMessage(session.ID, toolCall.ID, toolCall.Name, contentStr, toolCreatedAt, isError)
  2001	
  2002			callFP := canonicalFingerprint(toolCall.Name, toolCall.Arguments)
  2003			if isError {
  2004				// 与串行路径对齐：检测终端错误（配置/权限/白名单等不可重试错误），写入 terminalCache
  2005				if isTerminalError(contentStr) {
  2006					terminalCache[callFP] = contentStr
  2007					*terminalFailures = append(*terminalFailures, toolCall.Name)
  2008				}
  2009			} else {
  2010				approvedCalls[callFP] = true
  2011			}
  2012		}
  2013	}

