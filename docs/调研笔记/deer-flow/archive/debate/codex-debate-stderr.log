   142				expected: true,
   143			},
   144			{
   145				name:     "子域名匹配",
   146				domain:   "api.github.com",
   147				list:     []string{"github.com"},
   148				expected: true,
   149			},
   150			{
   151				name:     "www前缀忽略",
   152				domain:   "www.github.com",
   153				list:     []string{"github.com"},
   154				expected: true,
   155			},
   156			{
   157				name:     "不在列表中",
   158				domain:   "bitbucket.org",
   159				list:     []string{"github.com", "gitlab.com"},
   160				expected: false,
   161			},
   162			{
   163				name:     "空列表",
   164				domain:   "github.com",
   165				list:     []string{},
   166				expected: false,
   167			},
   168			{
   169				name:     "大小写不敏感",
   170				domain:   "GitHub.COM",
   171				list:     []string{"github.com"},
   172				expected: true,
   173			},
   174			{
   175				name:     "多级子域名",
   176				domain:   "v1.api.github.com",
   177				list:     []string{"github.com"},
   178				expected: true,
   179			},
   180		}
