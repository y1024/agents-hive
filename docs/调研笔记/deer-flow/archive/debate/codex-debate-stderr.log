    30	
    31	// DecodeContent 解码 ToolResult.Content 为纯文本。
    32	// 支持三种格式：
    33	// 1. JSON 字符串: "hello" -> hello
    34	// 2. MCP 格式: [{"type":"text","text":"hello"}] -> hello
    35	// 3. 原始字节: 直接返回
    36	func (r *ToolResult) DecodeContent() string {
    37		if r == nil || len(r.Content) == 0 {
    38			return ""
    39		}
    40		return DecodeToolContent(r.Content)
    41	}
    42	
    43	// DecodeToolContent 解码 json.RawMessage 格式的工具输出为纯文本。
    44	// 支持三种格式：
    45	// 1. JSON 字符串: "hello" -> hello
    46	// 2. MCP 格式: [{"type":"text","text":"hello"}] -> 所有 text 块拼接（换行分隔）
    47	// 3. 原始字节: 直接返回
    48	func DecodeToolContent(raw json.RawMessage) string {
    49		// 尝试作为 JSON 字符串解析
    50		var text string
    51		if err := json.Unmarshal(raw, &text); err == nil {
    52			return text
    53		}
    54	
    55		// 尝试作为 MCP 格式解析，拼接所有 text 块
    56		var mcpContent []map[string]any
    57		if err := json.Unmarshal(raw, &mcpContent); err == nil {
    58			var parts []string
    59			for _, item := range mcpContent {
    60				if item["type"] == "text" {
    61					if t, ok := item["text"].(string); ok {
    62						parts = append(parts, t)
    63					}
    64				}
    65			}
    66			if len(parts) > 0 {
    67				return strings.Join(parts, "\n")
    68			}
    69		}
    70	
    71		// 降级：返回原始字符串
    72		return string(raw)
    73	}
