    15	
    16	// FinderOption 配置 Finder 的可选行为
    17	type FinderOption func(*Finder)
    18	
    19	// WithNestedDiscovery 启用对给定根目录下 .claude/skills/ 子目录的递归发现
    20	func WithNestedDiscovery(root string) FinderOption {
    21		return func(f *Finder) {
    22			f.nestedRoot = root
    23		}
    24	}
    25	
    26	// WithRemoteURLs 启用从远程 URL 拉取 skill
    27	func WithRemoteURLs(urls []string, discovery *Discovery) FinderOption {
    28		return func(f *Finder) {
    29			f.remoteURLs = urls
    30			f.discovery = discovery
    31		}
    32	}
    33	
    34	// WithPublicSkillsDir 注册一个明确归属 public scope 的搜索路径（$HIVE_DATA/skills/public）
    35	func WithPublicSkillsDir(dir string) FinderOption {
    36		return func(f *Finder) {
    37			if dir != "" {
    38				f.scopedPaths = append(f.scopedPaths, scopedPath{path: dir, scope: ScopePublic})
    39			}
    40		}
    41	}
    42	
    43	// WithPersonalSkillsRoot 注册 personal skill 根目录（$HIVE_DATA/skills/users）。
    44	// Finder 在 Discover 时枚举子目录作为 userID，每个 userID 目录下的 skill 归属 personal scope。
    45	func WithPersonalSkillsRoot(root string) FinderOption {
    46		return func(f *Finder) {
    47			f.personalRoot = root
    48		}
    49	}
    50	
    51	type scopedPath struct {
    52		path  string
    53		scope SkillScope
    54	}
    55	
    56	// Finder 从文件系统发现和加载 skill
    57	type Finder struct {
    58		searchPaths  []string
    59		scopedPaths  []scopedPath // 显式声明 scope 的路径（public skills dir 等）
    60		personalRoot string       // personal skills 根，子目录名即 userID
    61		registry     *Registry
    62		logger       *zap.Logger
    63		nestedRoot   string     // 如果设置，在此根目录下递归发现 .claude/skills/
    64		discovery    *Discovery // 远程 skill 发现器
    65		remoteURLs   []string   // 远程 skill 仓库 URL 列表
    66	}
    67	
    68	// NewFinder 创建新的 skill finder
    69	func NewFinder(registry *Registry, logger *zap.Logger, searchPaths []string, opts ...FinderOption) *Finder {
    70		f := &Finder{
    71			searchPaths: searchPaths,
    72			registry:    registry,
    73			logger:      logger,
    74		}
    75		for _, opt := range opts {
    76			opt(f)
    77		}
    78		return f
    79	}
    80	
    81	// Discover 扫描搜索路径中的 SKILL.md 文件并返回发现的 skill
    82	// 处于 Level 1（仅元数据 — Content 为空）。
    83	//
    84	// 扫描顺序 + scope 归属：
    85	//  1. 旧 searchPaths（.claude/skills、~/.claude/skills、skills/）→ ScopePublic（向后兼容）
    86	//  2. scopedPaths（WithPublicSkillsDir 注册的 $HIVE_DATA/skills/public）→ ScopePublic
    87	//  3. personalRoot/<userID>/*（WithPersonalSkillsRoot 注册）→ ScopePersonal + userID
    88	//
    89	// frontmatter 中显式声明的 scope 始终优先于 path-inferred scope。
    90	func (f *Finder) Discover() ([]*Skill, error) {
    91		var discovered []*Skill
    92	
    93		for _, searchPath := range f.searchPaths {
    94			skills, err := f.discoverInPathScoped(searchPath, ScopePublic, "")
    95			if err != nil {
    96				return nil, err
    97			}
    98			discovered = append(discovered, skills...)
    99		}
   100	
   101		for _, sp := range f.scopedPaths {
   102			skills, err := f.discoverInPathScoped(sp.path, sp.scope, "")
   103			if err != nil {
   104				return nil, err
   105			}
   106			discovered = append(discovered, skills...)
   107		}
   108	
   109		if f.personalRoot != "" {
   110			personalSkills, err := f.discoverPersonalRoot(f.personalRoot)
   111			if err != nil {
   112				f.logger.Warn("personal skills 根目录扫描失败", zap.String("root", f.personalRoot), zap.Error(err))
   113			} else {
   114				discovered = append(discovered, personalSkills...)
   115			}
   116		}
   117	
   118		return discovered, nil
   119	}
   120	
   121	// discoverPersonalRoot 枚举 personalRoot 的一级子目录作为 userID，
   122	// 每个 userID 目录下的 skill 归属 ScopePersonal + 对应 userID。
   123	func (f *Finder) discoverPersonalRoot(root string) ([]*Skill, error) {
   124		info, err := os.Stat(root)
   125		if err != nil {
   126			if os.IsNotExist(err) {
   127				return nil, nil
   128			}
   129			return nil, errs.Wrap(errs.CodeSkillLoadFailed, fmt.Sprintf("stat personal root %q", root), err)
   130		}
   131		if !info.IsDir() {
   132			return nil, nil
   133		}
   134		entries, err := os.ReadDir(root)
   135		if err != nil {
   136			return nil, errs.Wrap(errs.CodeSkillLoadFailed, fmt.Sprintf("read personal root %q", root), err)
   137		}
   138		var all []*Skill
   139		for _, entry := range entries {
   140			if !entry.IsDir() {
   141				continue
   142			}
   143			userID := entry.Name()
   144			if userID == "" {
   145				continue
   146			}
   147			userDir := filepath.Join(root, userID)
   148			skills, err := f.discoverInPathScoped(userDir, ScopePersonal, userID)
   149			if err != nil {
   150				f.logger.Warn("personal user 目录扫描失败", zap.String("user_id", userID), zap.Error(err))
   151				continue
   152			}
   153			all = append(all, skills...)
   154		}
   155		return all, nil
   156	}
   157	
   158	// discoverInPath 扫描单个搜索路径中的 skill（兼容旧 caller，默认 public scope + 空 userID）
   159	func (f *Finder) discoverInPath(searchPath string) ([]*Skill, error) {
   160		return f.discoverInPathScoped(searchPath, ScopePublic, "")
   161	}
   162	
   163	// discoverInPathScoped 扫描单个路径，给发现的 skill 统一注入 scope + userID。
   164	// frontmatter 中显式声明的 scope 优先；若 path-inferred scope=personal 但 userID 空，skill 被拒绝。
   165	func (f *Finder) discoverInPathScoped(searchPath string, pathScope SkillScope, userID string) ([]*Skill, error) {
   166		info, err := os.Stat(searchPath)
   167		if err != nil {
   168			if os.IsNotExist(err) {
   169				f.logger.Debug("skill 搜索路径不存在", zap.String("path", searchPath))
   170				return nil, nil
   171			}
   172			return nil, errs.Wrap(errs.CodeSkillLoadFailed, fmt.Sprintf("stat %q", searchPath), err)
   173		}
   174		if !info.IsDir() {
   175			return nil, nil
   176		}
   177	
   178		entries, err := os.ReadDir(searchPath)
   179		if err != nil {
   180			return nil, errs.Wrap(errs.CodeSkillLoadFailed, fmt.Sprintf("read dir %q", searchPath), err)
   181		}
   182	
   183		var discovered []*Skill
   184		for _, entry := range entries {
   185			if !entry.IsDir() {
   186				continue
   187			}
   188			skillDir := filepath.Join(searchPath, entry.Name())
   189			skillFile := filepath.Join(skillDir, "SKILL.md")
   190	
   191			if _, err := os.Stat(skillFile); os.IsNotExist(err) {
   192				f.logger.Debug("目录没有 SKILL.md，跳过", zap.String("path", skillDir))
   193				continue
   194			}
   195	
   196			skill, err := discoverMetadataOnly(skillFile, skillDir)
   197			if err != nil {
   198				f.logger.Warn("解析 SKILL.md 失败", zap.String("path", skillFile), zap.Error(err))
   199				continue
   200			}
   201	
   202			// Validate name
   203			if err := ValidateName(skill.Metadata.Name); err != nil {
   204				f.logger.Warn("无效的 skill 名称，跳过",
   205					zap.String("name", skill.Metadata.Name),
   206					zap.String("path", skillDir),
   207					zap.Error(err))
   208				continue
   209			}
   210	
   211			// Validate name matches directory name
   212			if skill.Metadata.Name != filepath.Base(skillDir) {
   213				f.logger.Warn("skill 名称与目录名不匹配，跳过",
   214					zap.String("name", skill.Metadata.Name),
   215					zap.String("dir", filepath.Base(skillDir)),
   216					zap.String("path", skillDir))
   217				continue
   218			}
   219	
   220			// Validate compatibility length
   221			if len(skill.Metadata.Compatibility) > 500 {
   222				f.logger.Warn("skill 兼容性字段超过 500 字符，跳过",
   223					zap.String("name", skill.Metadata.Name),
   224					zap.String("path", skillDir))
   225				continue
   226			}
   227	
   228			// Validate description length
   229			if len(skill.Metadata.Description) > 1024 {
   230				f.logger.Warn("skill 描述超过 1024 字符，跳过",
   231					zap.String("name", skill.Metadata.Name),
   232					zap.String("path", skillDir),
   233					zap.Int("length", len(skill.Metadata.Description)))
   234				continue
   235			}
   236	
   237			// 应用 scope 归属：frontmatter 显式声明优先，否则用 path-inferred
   238			effectiveScope := skill.Metadata.Scope
   239			if effectiveScope == "" {
   240				effectiveScope = pathScope
   241			}
   242			if !effectiveScope.Valid() {
   243				f.logger.Warn("skill scope 无效，跳过",
   244					zap.String("name", skill.Metadata.Name),
   245					zap.String("scope", string(effectiveScope)),
   246					zap.String("path", skillDir))
   247				continue
   248			}
   249	
   250			// personal scope 必须携带 userID（path-inferred 时由目录名注入，frontmatter 声明 personal 但 path 无 userID → 拒绝）
   251			if effectiveScope == ScopePersonal && userID == "" {
   252				f.logger.Warn("personal scope skill 缺少 userID，跳过",
   253					zap.String("name", skill.Metadata.Name),
   254					zap.String("path", skillDir))
   255				continue
   256			}
   257	
   258			skill.Metadata.Scope = effectiveScope
   259			if effectiveScope == ScopePersonal {
   260				skill.Metadata.UserID = userID
   330	// Count 返回当前视图下的 skill 数量。
   331	// Count()：仅 public 层；Count(userID)：personal + public 合并后去重。
   332	func (r *Registry) Count(userID ...string) int {
   333		return len(r.List(userID...))
   334	}
   335	
   336	// ListForModel 返回未禁用模型调用的 skill 元数据（合并 personal + public，personal 覆盖）
   337	func (r *Registry) ListForModel(userID ...string) []SkillMetadata {
   338		all := r.List(userID...)
   339		result := make([]SkillMetadata, 0, len(all))
   340		for _, m := range all {
   341			if !m.DisableModelInvocation {
   342				result = append(result, m)
   343			}
   344		}
   345		return result
   346	}
   347	
   348	// ListUserInvocable 返回用户可调用的 skill（合并 personal + public，personal 覆盖）
   349	func (r *Registry) ListUserInvocable(userID ...string) []SkillMetadata {
   350		all := r.List(userID...)
   351		result := make([]SkillMetadata, 0, len(all))
   352		for _, m := range all {
   353			if m.IsUserInvocable() {
   354				result = append(result, m)
   355			}
   356		}
   357		return result
   358	}
   359	
   360	// FindBySpecRequirements 返回声明的 ProvidesRequirements 与 reqs 有交集的 skill。
   361	// 最小实现：spec-driven-subagents 合入后会被其真实逻辑替换。
   362	func (r *Registry) FindBySpecRequirements(reqs []string, userID string) []*Skill {
   363		if len(reqs) == 0 {
   364			return nil
   365		}
   366		reqSet := make(map[string]bool, len(reqs))
   367		for _, req := range reqs {
   368			reqSet[req] = true
   369		}
   370		r.mu.RLock()
   371		defer r.mu.RUnlock()
   372	
   373		// personal 先查
   374		var matched []*Skill
   375		seenName := make(map[string]bool)
   376		consider := func(key registryKey, s *Skill) {
   377			if seenName[key.Name] {
   378				return
   379			}
   380			for _, p := range s.Metadata.ProvidesRequirements {
   381				if reqSet[p] {
   382					matched = append(matched, s)
   383					seenName[key.Name] = true
   384					return
   385				}
   386			}
   387		}
   388		if userID != "" {
   389			for key, s := range r.skills {
   390				if key.UserID == userID {
   391					consider(key, s)
   392				}
   393			}
   394		}
   395		for key, s := range r.skills {
   396			if key.UserID == "" {
   397				consider(key, s)
   398			}
   399		}
   400		return matched
   401	}
   402	
   403	// RegisterFromPath 扫描单个 skill 目录（含 SKILL.md），解析 frontmatter 后注册。
   404	// scope / userID 参数覆盖 frontmatter（bootstrap/install 场景下由外部强制指定）。
   405	func (r *Registry) RegisterFromPath(_ context.Context, path string, scope SkillScope, userID string) error {
   406		if scope == "" {
   407			scope = ScopePublic
   408		}
   409		if scope == ScopePersonal && userID == "" {
   410			return errs.New(errs.CodeSkillInvalidName,
   411				fmt.Sprintf("RegisterFromPath: personal scope requires userID (path=%s)", path))
   412		}
   413		skill, err := loadSkillFromDir(path)
   414		if err != nil {
   415			return err
   416		}
   417		skill.Metadata.Scope = scope
   418		if scope == ScopePersonal {
   419			skill.Metadata.UserID = userID
