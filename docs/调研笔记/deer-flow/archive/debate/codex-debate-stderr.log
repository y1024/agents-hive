    25		"github.com/chef-guo/agents-hive/internal/tools"
    26	)
    27	
    28	// directExecParams 直接执行路径的前置准备参数
    29	type directExecParams struct {
    30		sessionLLM      *llm.Client
    31		availableTools  []mcphost.ToolDefinition
    32		systemPrompt    string
    33		reasoningEffort string
    34	}
    35	
    36	// prepareDirectExecParams 准备直接执行路径的共享参数。
    37	func (m *Master) prepareDirectExecParams(ctx context.Context, session *SessionState) (*directExecParams, error) {
    38		sessionLLM := m.getSessionLLM(session)
    39		if sessionLLM == nil {
    40			// error 终态由 processTask defer 统一广播
    41			return nil, errs.New(errs.CodeInvalidInput, "LLM client not configured (API key required)")
    42		}
    43	
    44		// 获取可用工具
    45		var availableTools []mcphost.ToolDefinition
    46		if m.toolBridge != nil {
    47			allTools := m.toolBridge.AvailableTools(nil)
    48			availableTools = m.toolBridge.AvailableTools(m.masterFilter)
    49			if len(availableTools) != len(allTools) {
    50				m.logger.Debug("工具策略过滤生效",
    51					zap.Int("total_tools", len(allTools)),
    52					zap.Int("filtered_tools", len(availableTools)))
    53			}
    54		} else if m.mcpHost != nil {
    55			availableTools = m.mcpHost.ListTools()
    56		}
    57		systemPrompt := m.buildSystemPrompt(availableTools)
    58	
    59		// 记忆注入
    60		if m.memoryInjector != nil {
    61			lastUserMsg := ""
    62			session.mu.RLock()
    63			for i := len(session.Messages) - 1; i >= 0; i-- {
    64				if session.Messages[i].Role == "user" {
    65					lastUserMsg = session.Messages[i].Content.Text()
    66					break
    67				}
    68			}
    69			session.mu.RUnlock()
    70			if lastUserMsg != "" {
    71				userID := auth.UserIDFrom(ctx)
    72				memCtx, err := m.memoryInjector.InjectContext(ctx, lastUserMsg, session.ID, userID)
    73				if err != nil {
    74					m.logger.Warn("记忆注入失败", zap.Error(err))
    75				} else if memCtx != "" {
    76					systemPrompt += "\n" + memCtx
    77				}
    78			}
    79		}
    80	
    81		// 插件 ChatMessageBefore hook
    82		if m.pluginMgr != nil {
    83			session.mu.RLock()
    84			msgSnapshot := make([]llm.MessageWithTools, len(session.Messages))
    85			copy(msgSnapshot, session.Messages)
    86			session.mu.RUnlock()
    87	
    88			chatInput := &plugin.ChatMessageInput{
    89				SessionID:    session.ID,
    90				SystemPrompt: systemPrompt,
    91				Messages:     msgSnapshot,
    92				Agent:        "default",
    93			}
    94			if err := m.pluginMgr.TriggerChatBefore(ctx, chatInput); err != nil {
    95				m.logger.Warn("插件 ChatMessageBefore hook 失败", zap.Error(err))
    96			} else {
    97				systemPrompt = chatInput.SystemPrompt
    98			}
    99		}
   100	
   101		// 读取推理努力级别和模型覆盖
   102		_, reasoningEffort, modelOverride := session.GetPendingData()
   103	
   104		// 模型覆盖
   105		if modelOverride != "" && modelOverride != sessionLLM.Model() {
   106			m.llmMu.RLock()
   107			baseCfg := m.config
   108			m.llmMu.RUnlock()
   109			provDef := llm.LookupProvider(baseCfg.Provider)
   110			provDef.APIFormat = baseCfg.APIFormat
   111			overrideClient := m.llmPool.Get(llm.ClientConfig{
   112				APIKey:          baseCfg.APIKey,
   113				BaseURL:         baseCfg.BaseURL,
   114				Model:           modelOverride,
   115				DisableJSONMode: baseCfg.DisableJSONMode,
   116				Provider:        provDef,
   117				ReasoningEffort: baseCfg.ReasoningEffort,
   118				StorePrivacy:    baseCfg.StorePrivacy,
   119			})
   120			if overrideClient != nil {
   121				sessionLLM = overrideClient
   122				m.logger.Info("使用 skill 模型覆盖",
   123					zap.String("model", modelOverride),
   124					zap.String("session_id", session.ID),
   125				)
   126			} else {
   127				m.logger.Warn("模型覆盖失败：llmPool 返回 nil，回退到默认模型",
   128					zap.String("requested_model", modelOverride),
   129					zap.String("fallback_model", sessionLLM.Model()),
   130					zap.String("session_id", session.ID),
   131				)
   132				m.eventBus.BroadcastSessionMessage(session.ID, BroadcastMessage{
   133					Type: EventTypeAgentStatus,
   134					Payload: map[string]interface{}{
   135						"status":     "warning",
   136						"session_id": session.ID,
   137						"warning":    fmt.Sprintf("模型 %q 不可用，已回退到 %s", modelOverride, sessionLLM.Model()),
   138					},
   139				})
   140			}
   141		}
   142	
   143		return &directExecParams{
   144			sessionLLM:      sessionLLM,
   145			availableTools:  availableTools,
   146			systemPrompt:    systemPrompt,
   147			reasoningEffort: reasoningEffort,
   148		}, nil
   149	}
   150	
   151	// processTaskDirectExec 使用 ReAct Tool-Use 循环处理任务。
   152	// Master 拥有所有常用工具（master_direct profile），直接执行用户任务。
   153	func (m *Master) processTaskDirectExec(ctx context.Context, request string, session *SessionState, responseID uint64, sessionTraceID, sessionSpanID string, skipUserMsg bool) error {
   154		if m.agentFactory != nil {
   155			defer m.agentFactory.CleanupBySession(session.ID)
   156		}
   157	
   158		// 读取附件并构建用户消息
   159		pendingAttachments, _, _ := session.GetPendingData()
   160		userContent := m.buildUserContent(ctx, request, pendingAttachments)
   161	
   162		if !skipUserMsg {
   163			userCreatedAt := time.Now().Format(time.RFC3339)
   164			m.appendSessionMessage(session, llm.MessageWithTools{
   165				Role:      "user",
   166				Content:   userContent,
   167				CreatedAt: userCreatedAt,
   168			})
   169	
   170			// 广播用户消息确认
   171			// X-1: 使用 BroadcastSessionMessage 填充 top-level SessionID，
   172			// 防止同一飞书群聊内两个 session 互相看到对方的 token。
   173			m.eventBus.BroadcastSessionMessage(session.ID, BroadcastMessage{
   174				Type: EventTypeMessage,
   175				Payload: map[string]any{
   176					"role":       "user",
   177					"content":    userContent.Text(),
   178					"timestamp":  userCreatedAt,
   179					"session_id": session.ID,
   180				},
   181			})
   182		}
   183	
   184		// 图片附件自动路由到 Vision 模型
   185		if hasImageAttachments(pendingAttachments) && m.router != nil {
   186			if visionLLM := m.router.GetLLMClient(airouter.TaskVision); visionLLM != nil {
   187				m.logger.Info("检测到图片附件，路由到 Vision 模型",
   188					zap.String("vision_model", visionLLM.Model()),
   189					zap.String("session_id", session.ID),
   190				)
   191				// 临时覆盖 session LLM（prepareDirectExecParams 会重新获取，这里提前设置）
   192				session.mu.Lock()
   193				session.activeModel = visionLLM.Model()
   194				session.mu.Unlock()
   195			}
   196		}
   197	
   198		params, err := m.prepareDirectExecParams(ctx, session)
   199		if err != nil {
   200			return err
   201		}
   202	
   203		return m.runReActLoop(ctx, session, responseID, params.sessionLLM, params.availableTools, params.systemPrompt, params.reasoningEffort, sessionTraceID, sessionSpanID)
   204	}
   205	
   206	// runReActLoop 执行核心 ReAct 迭代循环（LLM 调用 → 工具执行 → 广播）。
   207	// runReActLoop 是 Master 的核心 ReAct 循环。
   208	func (m *Master) runReActLoop(
   209		ctx context.Context,
   210		session *SessionState,
   211		responseID uint64,
   212		sessionLLM *llm.Client,
   213		availableTools []mcphost.ToolDefinition,
   214		systemPrompt string,
   215		reasoningEffort string,
   216		sessionTraceID, sessionSpanID string,
   217	) error {
   218		const temperature float64 = 0.3 // P0-3: 从 0.7 降到 0.3，减少随机性，提升代码生成确定性
   219		const maxTokens int64 = 0
   220	
   221		// Task 4.4（harden-spec-driven-phase2）：runReActLoop 入口 atomic 读 specCtx 打诊断日志。
   222		// 零锁（atomic.Pointer.Load）、零业务影响——仅 Debug 日志，生产 grep 排查
   223		// "为什么这个 session 没走 spec" 时可快速定位 plumbing 是否抵达 react 层。
   224		logSpecCtxAtReactEntry(m.logger, session)
   225	
   226		// P0-3 Phase 5: 循环检测器，滑动窗口 20 轮
   227		detector := newLoopDetector(20)
   228	
   229		// 终端错误缓存：key = "toolName:args"，value = 错误内容
   230		// 同一 tool+args 组合遇到不可重试错误后，后续相同调用直接返回缓存错误，不再执行
   231		terminalCache := make(map[string]string)
   232	
   233		// 审批缓存：key = "toolName:args"，记录同任务内已审批通过的 tool+args 组合
   234		// 避免 LLM 重试相同调用时重复弹出审批卡片
   235		approvedCalls := make(map[string]bool)
   236	
   237		// ── Phase 5B：配额检查（只在入口检查一次）──
   238		userID := auth.UserIDFrom(ctx)
   239		if userID != "" && m.authEngine != nil {
   240			if err := m.authEngine.CheckQuota(ctx, userID); err != nil {
   241				return err
   242			}
   243		}
   244	
   245		// P0-A C2：required+0-tool-call 兜底计数器。
   246		// 跨迭代累计：本任务内允许 1 次追责重试，第 2 次仍 required+0 就结构化失败。
   247		var requiredBreachCount int
   248	
   249		for i := 0; ; i++ {
   250			// P0-3 Phase 5.3: per-session 成本预算检查（每轮检查，防止 fan-out turn 耗尽预算后无感知）
   251			if costErr := m.checkCostBudget(ctx, session.ID); costErr != nil {
   252				m.logger.Warn("会话成本已达上限",
   253					zap.String("session_id", session.ID),
   254					zap.Error(costErr),
   255				)
   256				m.appendSessionMessage(session, llm.MessageWithTools{
   257					Role:      "system",
   258					Content:   llm.NewTextContent(costErr.Error()),
   259					CreatedAt: time.Now().Format(time.RFC3339),
   260					Metadata:  map[string]string{"agent_id": "master"},

 succeeded in 0ms:
   260					Metadata:  map[string]string{"agent_id": "master"},
   261				})
   262				// error 终态由 processTask defer 统一广播
   263				return costErr
   264			}
   265	
   266			// 广播当前轮次进度，用于前端活动面板的 Turn 进度条
   267			// X-1: 填充 top-level SessionID 防止跨 session 泄漏。
   268			m.eventBus.BroadcastSessionMessage(session.ID, BroadcastMessage{
   269				Type: EventTypeAgentProgress,
   270				Payload: map[string]any{
   271					"turn":         i + 1,
   272					"max_turns":    0,
   273					"status":       "turn_start",
   274					"session_id":   session.ID,
   275					"agent_id":     "master",
   276					"agent_type":   "master",
   277					"route_reason": "direct",
   278				},
   279			})
   280	
   281			// 每轮迭代开始时重置为 thinking，避免上一轮 tool_calling 状态粘住前端指示器。
   282			// i==0 首轮由 processTask 入口广播 thinking，此处从 i>=1 开始补发。
   283			if i > 0 {
   284				m.eventBus.BroadcastSessionMessage(session.ID, BroadcastMessage{
   285					Type: EventTypeAgentStatus,
   286					Payload: map[string]interface{}{
   287						"status":     "thinking",
   288						"session_id": session.ID,
   289					},
   290				})
   291			}
   292	
   293			// 读取消息快照，在锁外执行耗时的修复和压缩操作
   294			session.mu.Lock()
   295			repairedMessages, patchedMsgs := repairOrphanedToolCalls(session.Messages, m.logger)
   296			session.Messages = repairedMessages
   297			msgsCopy := make([]llm.MessageWithTools, len(session.Messages))
   298			copy(msgsCopy, session.Messages)
   299			session.mu.Unlock()
   300			// 将修复插入的假 tool result 持久化到 DB，避免重启后重复警告
   301			for _, pm := range patchedMsgs {
   302				m.appendSessionMessage(session, pm)
   303			}
   304	
   305			m.logger.Info("ReAct 迭代开始",
   306				zap.Int("iteration", i+1),
   307				zap.String("max", "unlimited"),
   308				zap.Int("messages", len(msgsCopy)),
   309			)
   310	
   311			// 使用新的上下文压缩机制（在锁外执行，避免长时间持锁）
   312			preparedMessages := m.prepareMessagesWithCompression(ctx, session, msgsCopy)
   313			// 移除孤立的 tool result（压缩可能导致 assistant tool_call 被截断而 tool result 保留）
   314			preparedMessages = removeOrphanedToolResults(preparedMessages, m.logger)
   315	
   316			m.logger.Info("发起 LLM 调用",
   317				zap.String("session_id", session.ID),
   318				zap.String("model", sessionLLM.Model()),
   319				zap.Int("iteration", i+1),
   320				zap.Int("tools_available", len(availableTools)),
   321			)
   322			llmCallStart := time.Now()
   323			llmSpanID := observability.NewSpanID()
   324			lastStreamBroadcast := time.Time{}
   325			const streamThrottleInterval = 50 * time.Millisecond
   326			// 诊断计数：chunk 到达节奏（排查"假流式"：provider 是否按 SSE 逐步吐 token）
   327			var chunkCount int
   328			var firstChunkAt time.Time
   329			var lastContentLen int
   330	
   331			// P0-A：根据 feature flag 决定本轮 ToolChoice 策略。
   332			// Flag 关闭时保持旧 auto 行为（空字符串透传，SDK 自行默认）。
   333			var toolChoice string
   334			if m.config.QualityGuards.ToolChoiceForce {
   335				latestQuery := extractLatestUserQuery(preparedMessages)
   336				// H3：注入真实 skillsIndex —— 让 "X 是什么 / 怎么用" 且 X 已知时回落到 auto，
   337				// 避免对自家 skill 的闲聊式介绍也强制 required。nil 时 detectToolChoice
   338				// 退化为保守立场（只要命中 whatIs 模式就 required）。
   339				toolChoice = detectToolChoice(latestQuery, m.buildSkillsIndex(userID))
   340				m.logger.Info("[quality-guards] P0-A tool_choice 决策",
   341					zap.String("session_id", session.ID),
   342					zap.Int("iteration", i+1),
   343					zap.String("query_preview", truncateForLog(latestQuery, 80)),
   344					zap.String("tool_choice", toolChoice),
   345				)
   346			}
   347	
   348			llmReq := llm.ChatWithToolsRequest{
   349				SystemPrompt:    systemPrompt,
   350				Messages:        preparedMessages,
   351				Tools:           availableTools,
   352				Temperature:     temperature,
   353				MaxTokens:       maxTokens,
   354				ReasoningEffort: reasoningEffort,
   355				ToolChoice:      toolChoice,
   356			}
   357			resp, err := sessionLLM.ChatWithToolsStream(ctx, llmReq, func(chunk llm.StreamChunk) error {
   358				if chunk.Done {
   359					return nil
   360				}
   361				// 有可见内容或推理内容时才推送
   362				if chunk.ContentSoFar == "" && chunk.ReasoningContent == "" {
   363					return nil
   364				}
   365				// 诊断：记录首个 chunk 抵达耗时 + 前 3 个 chunk 的节奏
   366				chunkCount++
   367				if chunkCount == 1 {
   368					firstChunkAt = time.Now()
   369					m.logger.Info("[stream-diag] 首个 LLM chunk 抵达",
   370						zap.String("session_id", session.ID),
   371						zap.Int64("ttfb_ms", time.Since(llmCallStart).Milliseconds()),
   372						zap.Int("content_len", len(chunk.ContentSoFar)),
   373					)
   374				} else if chunkCount <= 3 || chunkCount%20 == 0 {
   375					m.logger.Info("[stream-diag] chunk 抵达",
   376						zap.String("session_id", session.ID),
   377						zap.Int("n", chunkCount),
   378						zap.Int64("elapsed_since_start_ms", time.Since(llmCallStart).Milliseconds()),
   379						zap.Int64("elapsed_since_first_ms", time.Since(firstChunkAt).Milliseconds()),
   380						zap.Int("content_len", len(chunk.ContentSoFar)),
   381						zap.Int("content_delta_len", len(chunk.ContentSoFar)-lastContentLen),
   382					)
   383				}
   384				lastContentLen = len(chunk.ContentSoFar)
   385				// P0-A/C3 round-4：tool_choice=required 时抑制流式 partial assistant 广播。
   386				// 反例（修复前）：required + 模型硬抗不调工具时，回调会把凭记忆胡编的 token
   387				// 一帧一帧推给前端 UI，用户已经看见坏回答；等 guard 在终态 retry/fail 时，
   388				// 坏内容已经 render。屏蔽 partial 后：
   389				//   - 模型最终调了工具（pass）→ 由 L644 终态 broadcast 一次性出完整内容
   390				//   - 模型硬抗（retry/fail）→ 坏回答从未触达前端
   391				// 代价：required 模式失去流式体感。但 required 场景文本价值本来就低（真回答靠工具）。
   392				if shouldSuppressStreamPartial(toolChoice) {
   393					return nil
   394				}
   395				// 限速：最多 20fps，避免高速流式输出时撑爆 EventBus 订阅者通道
   396				now := time.Now()
   397				if now.Sub(lastStreamBroadcast) < streamThrottleInterval {
   398					return nil
   399				}
   400				lastStreamBroadcast = now
   401				payload := map[string]interface{}{
   402					"role":       "assistant",
   403					"content":    chunk.ContentSoFar,
   404					"session_id": session.ID,
   405					"partial":    true,
   406				}
   407				if chunk.ReasoningContent != "" {
   408					payload["reasoning_content"] = chunk.ReasoningContent
   409				}
   410				// X-1: 填充 top-level SessionID 防止跨 session 泄漏。
   411				m.eventBus.BroadcastSessionMessage(session.ID, BroadcastMessage{
   412					Type:    EventTypeMessage,
   413					Payload: payload,
   414				})
   415				return nil
   416			})
   417			if chunkCount > 0 {
   418				m.logger.Info("[stream-diag] LLM 流结束汇总",
   419					zap.String("session_id", session.ID),
   420					zap.Int("total_chunks", chunkCount),
   421					zap.Int64("total_ms", time.Since(llmCallStart).Milliseconds()),
   422					zap.Int64("ttfb_ms", firstChunkAt.Sub(llmCallStart).Milliseconds()),
   423					zap.Int64("stream_span_ms", time.Since(firstChunkAt).Milliseconds()),
   424				)
   425			} else {
   426				m.logger.Warn("[stream-diag] LLM 调用未收到任何 chunk（假流式或 provider 不 SSE）",
   427					zap.String("session_id", session.ID),
   428					zap.Int64("total_ms", time.Since(llmCallStart).Milliseconds()),
   429				)
   430			}
   431			llmDurationMs := time.Since(llmCallStart).Milliseconds()
   432	
   433			if err != nil {
   434				// LLM 调用失败时写入 error trace
   435				m.enqueueSpan(observability.Span{
   436					TraceID:      sessionTraceID,
   437					SpanID:       llmSpanID,
   438					ParentSpanID: sessionSpanID,
   439					Operation:    "llm.call",
   440					Service:      "master",
   441					SessionID:    session.ID,
   442					UserID:       userID,
   443					DurationMs:   int(llmDurationMs),
   444					Status:       "error",
   445					Attributes:   map[string]any{"model": sessionLLM.Model(), "error": err.Error()},
   446					Ts:           llmCallStart,
   447				})
   448				// error 终态由 processTask defer 统一广播，此处不重复
   449				return errs.Wrap(errs.CodePlanExecFailed, "LLM 调用失败", err)
   450			}
   451	
   452			// nil response 防御：LLM 返回 nil 但无 error（不应发生，但防御性处理）
   453			// 加 1 次重试：底层 resilience.Do 不会触发（因为无 error），所以这里手动重试一次
   454			if err := validateLLMResponse(resp); err != nil {
   455				m.logger.Warn("LLM 返回 nil response（无 error），尝试重试 1 次",
   456					zap.String("session_id", session.ID),
   457					zap.String("model", sessionLLM.Model()),
   458					zap.Int("iteration", i+1),
   459				)
   460				// 重试 1 次（复用首发完整请求参数，包括 ToolChoice — 否则 P0-A 在最该兜底的路径失效）
   461				// 注意：这里必须用 "=" 而非 ":="，否则 resp 被 shadow，外层拿不到重试成功的响应。
   462				retryStart := time.Now()
   463				var retryErr error
   464				resp, retryErr = sessionLLM.ChatWithToolsStream(ctx, llmReq, func(chunk llm.StreamChunk) error { return nil })
   465				retryDuration := time.Since(retryStart).Milliseconds()
   466				if retryErr != nil || validateLLMResponse(resp) != nil {
   467					finalErr := err
