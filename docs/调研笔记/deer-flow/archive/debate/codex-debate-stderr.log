   139	// CreateAgent 根据规格创建动态 Agent 并启动
   140	func (f *AgentFactory) CreateAgent(ctx context.Context, spec AgentSpec) (Agent, error) {
   141		// 第一阶段：持锁完成验证、构建、注册、跟踪
   142		agent, err := f.createAgentLocked(ctx, spec)
   143		if err != nil {
   144			return nil, err
   145		}
   146	
   147		// 第二阶段：锁外启动 goroutine 并等待就绪（避免持锁期间 sleep）
   148		go agent.Run(ctx)
   149	
   150		// 等待 agent 启动完成（避免 SendTask 时 status 仍为 Stopped 的竞态）
   151		for i := 0; i < 100; i++ {
   152			if agent.Status() == StatusRunning {
   153				break
   154			}
   155			select {
   156			case <-ctx.Done():
   157				// 上下文取消，清理已注册但未就绪的 agent
   158				if destroyErr := f.DestroyAgent(agent.ID()); destroyErr != nil {
   159					f.logger.Warn("清理未就绪的动态 agent 失败", zap.String("id", agent.ID()), zap.Error(destroyErr))
   160				}
   161				return nil, errs.Wrap(errs.CodeCanceled, "等待 agent 启动时上下文已取消", ctx.Err())
   162			default:
   163			}
   164			time.Sleep(time.Millisecond)
   165		}
   166	
   167		return agent, nil
   168	}
   169	
   170	// createAgentLocked 在持锁状态下完成 agent 的验证、构建、注册和跟踪
   171	func (f *AgentFactory) createAgentLocked(ctx context.Context, spec AgentSpec) (*BaseAgent, error) {
   172		f.mu.Lock()
   173		defer f.mu.Unlock()
   174	
   175		// 自动生成 ID
   176		if spec.ID == "" {
   177			spec.ID = "dyn-" + uuid.New().String()[:8]
   178		}
   179	
   180		// 从 ctx 提取 sessionID（必须由调用方注入）
   181		sessionID := toolctx.GetSessionID(ctx)
   182		if sessionID == "" {
   183			return nil, errs.New(errs.CodeInvalidInput, "CreateAgent 要求 ctx 中包含 sessionID（通过 toolctx.WithSessionID 注入）")
   184		}
   185	
   186		// 初始化 session 桶
   187		if f.dynamicAgents[sessionID] == nil {
   188			f.dynamicAgents[sessionID] = make(map[string]*BaseAgent)
   189		}
