   928	// toolResult 工具执行结果
   929	type toolResult struct {
   930		Content  string
   931		IsError  bool
   932		Terminal bool // 终端错误：配置/权限/白名单等不可重试错误，LLM 不应重试相同调用
   933	}
   934	
   935	// terminalErrorPatterns 已知的不可重试错误模式（配置类、权限类、白名单类）
   936	// 匹配工具返回内容中的关键词，命中即标记为 terminal
   937	// 注意：瞬态错误（rate limit、timeout）不在此列表中，它们可以重试
   938	var terminalErrorPatterns = []string{
   939		"not in whitelist",
   940		"ip whitelist",
   941		"白名单",
   942		"invalid ip",
   943		"unauthorized",
   944		"403 forbidden",
   945		"permission denied",
   946		"access denied",
   947		"invalid credentials",
   948		"account suspended",
   949		"工具策略拒绝",
   950		"不在当前 profile 的允许列表中",
   951		"不存在。可用工具",
   952	}
   953	
   954	// isTerminalError 检查工具执行结果是否为不可重试的终端错误
   955	func isTerminalError(content string) bool {
   956		lower := strings.ToLower(content)
   957		for _, pattern := range terminalErrorPatterns {
   958			if strings.Contains(lower, pattern) {
   959				return true
   960			}
   961		}
   962		return false
   963	}
   964	
   965	// canonicalFingerprint 生成工具调用的规范化 fingerprint（tool + 规范化 args）
   966	// 通过 unmarshal/marshal 消除 JSON key order 和 whitespace 差异
   967	func canonicalFingerprint(toolName string, args json.RawMessage) string {
   968		var normalized json.RawMessage
   969		var obj map[string]interface{}
   970		if json.Unmarshal(args, &obj) == nil {
   971			if b, err := json.Marshal(obj); err == nil {
   972				normalized = b
   973			}
   974		}
   975		if normalized == nil {
   976			normalized = args
   977		}
   978		return toolName + ":" + string(normalized)
   979	}
