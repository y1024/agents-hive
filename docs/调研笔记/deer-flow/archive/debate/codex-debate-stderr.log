    11	// criticalEventTimeout 是关键事件异步重试的最长等待时间。
    12	// HITL 事件（如 input_request）需要可靠送达，30 秒容忍网络波动和浏览器后台。
    13	// 后台 goroutine 在此时间内仍未送达则放弃，以防止 goroutine 泄漏。
    14	const criticalEventTimeout = 30 * time.Second
    15	
    16	// subscriberBufferSize 是每个订阅者通道的缓冲容量。
    17	// 从 32 提升到 256，为突发事件提供更大的缓冲余量，降低丢弃概率。
    18	const subscriberBufferSize = 256
    19	
    20	// deadSubscriberThreshold 是连续丢弃次数的阈值。
    21	// 超过此阈值的订阅者将被标记为"死"订阅者，可通过 PruneDeadSubscribers 清理。
    22	const deadSubscriberThreshold = 10
    23	
    24	// isCriticalEvent 判断消息类型是否属于关键事件。
    25	// 关键事件不允许静默丢弃：丢失会导致 HITL 流程无法推进。
    26	func isCriticalEvent(msgType string) bool {
    27		switch msgType {
    28		case EventTypeInputRequest, // HITL 输入请求
    29			EventTypeInputResponse, // HITL 输入响应（EmitInputRequest 订阅依赖）
    30			"approval_request",     // 审批请求（为未来扩展保留）
    31			EventTypeError,         // 错误通知
    32			EventTypeAgentStatus:   // Agent 状态变更（completed/error 丢失会导致前端卡在"思考中"）
    33			return true
    34		default:
    35			return false
    36		}
    37	}
