   108	// runTool 执行单个工具。
   109	func (se *StreamingExecutor) runTool(tool *TrackedTool) {
   110		// Bug 1 fix: 使用 closeDone() 而非直接 close，防止与 AbortAll 的 double-close panic
   111		defer tool.closeDone()
