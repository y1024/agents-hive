   133	// chatWithToolsViaResponses 通过 Responses API 实现带工具调用的 Chat。
   134	func (c *Client) chatWithToolsViaResponses(ctx context.Context, req ChatWithToolsRequest) (*ChatWithToolsResponse, error) {
   135		snapModel, _, _ := c.snapshot()
   136	
   137		// 构建 input items
   138		input := buildResponsesInputFromToolMessages(req.Messages)
   139	
   140		// 构建工具定义
   141		tools := convertToolsForResponses(req.Tools)
   142	
   143		params := responses.ResponseNewParams{
   144			Model: snapModel,
   145			Input: responses.ResponseNewParamsInputUnion{
   146				OfInputItemList: input,
   147			},
   148			Tools: tools,
   149		}
   150	
   151		// 系统提示 → Instructions
   152		if req.SystemPrompt != "" {
   153			params.Instructions = param.NewOpt(req.SystemPrompt)
