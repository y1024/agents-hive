  1050		// 其他工具统一 2 分钟超时，防止单工具阻塞整个 ReAct 循环
  1051		toolCtx := ctx
  1052		var toolCancel context.CancelFunc
  1053		switch toolCall.Name {
  1054		case "question", "parallel_dispatch", "task", "spawn_agent", "skill", "create_tool":
  1055			// 这些工具有自己的超时机制，不加额外超时
  1056		default:
  1057			toolCtx, toolCancel = context.WithTimeout(ctx, 2*time.Minute)
  1058			defer toolCancel()
  1059		}
  1060		// 优先走 ToolBridge（补齐插件 hooks、read_file 缓存、指标、tool-not-found 友好提示），
  1061		// fallback 到 mcpHost 直接执行（向后兼容测试场景）
  1062		var result *mcphost.ToolResult
  1063		var err error
  1064		if m.toolBridge != nil {
  1065			result, err = m.toolBridge.ExecuteDirect(toolCtx, toolCall.Name, args)
  1066		} else if m.mcpHost != nil {
  1067			result, err = m.mcpHost.ExecuteTool(toolCtx, toolCall.Name, args)
  1068		} else {
  1069			err = fmt.Errorf("no tool execution backend available")
  1070		}
  1071		duration := time.Since(start)
  1072		toolSpanID := observability.NewSpanID()
  1073	
  1074		// 统一工具执行结束日志：记录原始返回状态，方便排查工具调用链路问题
  1075		{
  1076			var contentPreview string
  1077			if result != nil {
  1078				contentPreview = mcphost.DecodeToolContent(result.Content)
  1079				if len(contentPreview) > 200 {
  1080					contentPreview = contentPreview[:200] + "..."
  1081				}
  1082			}
  1083			m.logger.Info("工具执行结束",
  1084				zap.String("tool", toolCall.Name),
  1085				zap.String("call_id", toolCall.ID),
  1086				zap.Int64("duration_ms", duration.Milliseconds()),
  1087				zap.Bool("has_error", err != nil),
  1088				zap.Bool("is_error", result != nil && result.IsError),
  1089				zap.String("content_preview", contentPreview),
  1090			)
  1091		}
  1092	
  1093		if err != nil {
  1094			m.logger.Warn("工具执行失败",
  1095				zap.String("tool", toolCall.Name),
  1096				zap.Error(err))
  1097			// 广播工具调用失败事件
  1098			m.emitToolCallEvent(sessionID, ToolCallEvent{
  1099				ToolCallID: toolCall.ID,
  1100				ToolName:   toolCall.Name,
  1101				Status:     "error",
  1102				Duration:   duration.Milliseconds(),
  1103				Error:      err.Error(),
  1104				SessionID:  sessionID,
  1105			})
  1106			m.enqueueSpan(observability.Span{
  1107				TraceID:      sessionTraceID,
  1108				SpanID:       toolSpanID,
  1109				ParentSpanID: sessionSpanID,
  1110				Operation:    "tool.execute",
  1111				Service:      "master",
  1112				SessionID:    sessionID,
  1113				UserID:       userID,
  1114				DurationMs:   int(duration.Milliseconds()),
  1115				Status:       "error",
  1116				Attributes:   map[string]any{"tool_name": toolCall.Name, "error": err.Error()},
  1117				Ts:           start,
  1118			})
  1119			m.enqueueMetric(observability.Metric{
  1120				Name:   "hive.tool.errors",
  1121				Value:  1,
  1122				Labels: map[string]any{"tool_name": toolCall.Name, "session_id": sessionID},
  1123			})
  1124			m.logToolCall(ctx, sessionID, toolCall, string(args), err.Error(), true, duration)
  1125			errMsg := fmt.Sprintf("[工具执行失败: %v]", err)
  1126			return toolResult{Content: errMsg, IsError: true, Terminal: isTerminalError(errMsg)}
  1127		}
  1128	
  1129		// 检查工具返回的 IsError 标记（工具执行成功但业务逻辑报错）
  1130		if result != nil && result.IsError {
  1131			decoded := mcphost.DecodeToolContent(result.Content)
  1132			m.emitToolCallEvent(sessionID, ToolCallEvent{
  1133				ToolCallID: toolCall.ID,
  1134				ToolName:   toolCall.Name,
  1135				Status:     "error",
  1136				Duration:   duration.Milliseconds(),
  1137				Error:      decoded,
  1138				SessionID:  sessionID,
  1139			})
  1140			m.enqueueSpan(observability.Span{
  1141				TraceID:      sessionTraceID,
  1142				SpanID:       toolSpanID,
  1143				ParentSpanID: sessionSpanID,
  1144				Operation:    "tool.execute",
  1145				Service:      "master",
  1146				SessionID:    sessionID,
  1147				UserID:       userID,
  1148				DurationMs:   int(duration.Milliseconds()),
  1149				Status:       "error",
  1150				Attributes:   map[string]any{"tool_name": toolCall.Name, "is_error": true},
  1151				Ts:           start,
  1152			})
  1153			m.logToolCall(ctx, sessionID, toolCall, string(args), decoded, true, duration)
  1154			return toolResult{Content: decoded, IsError: true, Terminal: isTerminalError(decoded)}
  1155		}
  1156	
  1157		// nil result 防御：先检查再记录，避免 broadcast success + span ok 与 IsError:true 矛盾
  1158		if result == nil {
  1159			m.logger.Warn("工具执行返回 nil result（无 error），标记为异常",
  1160				zap.String("tool", toolCall.Name),
  1161				zap.String("call_id", toolCall.ID),
  1162			)
  1163			m.emitToolCallEvent(sessionID, ToolCallEvent{
  1164				ToolCallID: toolCall.ID,
  1165				ToolName:   toolCall.Name,
  1166				Status:     "error",
  1167				Duration:   duration.Milliseconds(),
  1168				SessionID:  sessionID,
  1169			})
  1170			m.enqueueSpan(observability.Span{
  1171				TraceID:      sessionTraceID,
  1172				SpanID:       toolSpanID,
  1173				ParentSpanID: sessionSpanID,
  1174				Operation:    "tool.execute",
  1175				Service:      "master",
  1176				SessionID:    sessionID,
  1177				UserID:       userID,
  1178				DurationMs:   int(duration.Milliseconds()),
  1179				Status:       "error",
  1180				Attributes:   map[string]any{"tool_name": toolCall.Name, "error": "nil result"},
  1181				Ts:           start,
  1182			})
  1183			m.logToolCall(ctx, sessionID, toolCall, string(args), "[工具返回空结果]", true, duration)
  1184			return toolResult{Content: "[工具返回空结果]", IsError: true}
  1185		}
  1186	
  1187		// 广播工具调用成功事件
  1188		m.emitToolCallEvent(sessionID, ToolCallEvent{
  1189			ToolCallID: toolCall.ID,
  1190			ToolName:   toolCall.Name,
  1191			Status:     "success",
  1192			Duration:   duration.Milliseconds(),
  1193			SessionID:  sessionID,
  1194		})
  1195	
  1196		content := mcphost.DecodeToolContent(result.Content)
  1197		m.logger.Info("工具执行成功",
  1198			zap.String("tool", toolCall.Name),
  1199			zap.String("call_id", toolCall.ID),
  1200			zap.Int64("duration_ms", duration.Milliseconds()),
  1201			zap.Int("result_bytes", len(result.Content)),
  1202		)
  1203		// 工具执行成功 trace + metrics
  1204		m.enqueueSpan(observability.Span{
  1205			TraceID:      sessionTraceID,
  1206			SpanID:       toolSpanID,
  1207			ParentSpanID: sessionSpanID,
  1208			Operation:    "tool.execute",
  1209			Service:      "master",
  1210			SessionID:    sessionID,
  1720		}
  1721		return meta
  1722	}
  1723	
  1724	// emitToolCallEvent 广播工具调用事件，并把 SessionID 填到 top-level。
  1725	// X-1 修复：直接用 BroadcastGenericMessage 会丢失 top-level SessionID，
  1726	// 导致同一飞书群聊内两个 session 的 renderer 互相收到对方的 tool_call。
  1727	func (m *Master) emitToolCallEvent(sessionID string, ev ToolCallEvent) {
  1728		m.eventBus.BroadcastSessionMessage(sessionID, BroadcastMessage{
  1729			Type:    EventTypeToolCall,
  1730			Payload: ev,
  1731		})
  1732	}
  1733	
  1734	// broadcastToolMessage 广播 tool 消息给前端。
  1735	func (m *Master) broadcastToolMessage(sessionID, toolCallID, toolName, content, createdAt string, isError bool) {
  1736		payload := map[string]interface{}{
  1737			"role":         "tool",
  1738			"content":      content,
  1739			"session_id":   sessionID,
  1740			"partial":      false,
  1741			"tool_call_id": toolCallID,
  1742			"tool_name":    toolName,
  1743			"timestamp":    createdAt,
  1744		}
  1745		if isError {
  1746			payload["is_error"] = true
  1747		}
  1748		// X-1: 填充 top-level SessionID 防止跨 session 泄漏。
  1749		m.eventBus.BroadcastSessionMessage(sessionID, BroadcastMessage{
  1750			Type:    EventTypeMessage,
  1751			Payload: payload,
  1752		})
  1753	}
  1754	
  1755	// ensureWenyanTitle 检查 wenyan__publish_article 的 content 参数，
  1756	// 如果缺少 frontmatter title 则自动注入，避免 MCP 报 "未能找到文章标题"。
  1757	func ensureWenyanTitle(args json.RawMessage, logger *zap.Logger) json.RawMessage {
  1758		var m map[string]any
  1759		if err := json.Unmarshal(args, &m); err != nil {
  1760			logger.Warn("ensureWenyanTitle: 参数解析失败", zap.Error(err))
  1761			return args
  1762		}
  1763		contentRaw, ok := m["content"]
  1764		if !ok {
  1765			logger.Warn("ensureWenyanTitle: 参数中无 content 字段")
  1766			return args
  1767		}
  1768		content, ok := contentRaw.(string)
  1769		if !ok || content == "" {
  1770			logger.Warn("ensureWenyanTitle: content 为空或非字符串", zap.Bool("is_string", ok))
  1771			return args
  1772		}
  1773	
  1774		// 检查是否已有 frontmatter
  1775		hasFrontmatter := false
  1776		fmEndPos := -1 // content 中第二个 "---" 的起始位置（绝对偏移）
  1777		if strings.HasPrefix(content, "---") {
  1778			idx := strings.Index(content[3:], "\n---")
  1779			if idx >= 0 {
  1780				fmEndPos = idx + 3 // "\n---" 中 '\n' 的位置
  1781				fm := content[3:fmEndPos]
  1782				hasFrontmatter = true
  1783				if strings.Contains(fm, "\ntitle:") || strings.HasPrefix(fm, "title:") {
  1784					return args // 已有 title，不需要注入
  1785				}
  1786			}
  1787		}
  1788	
  1789		// 从正文提取标题：优先取 # 标题行，其次取前 30 个非空字符
  1790		// 如果有 frontmatter，只在 frontmatter 之后的正文中搜索
  1791		bodyForSearch := content
  1792		if hasFrontmatter {
  1793			// 跳过 frontmatter block（包括结尾的 "---\n"）
  1794			afterFM := fmEndPos + 4 // 跳过 "\n---"
  1795			if afterFM < len(content) {
  1796				bodyForSearch = content[afterFM:]
  1797			}
  1798		}
  1799		var title string
  1800		for _, line := range strings.Split(bodyForSearch, "\n") {
  1801			line = strings.TrimSpace(line)
  1802			if line == "" || line == "---" {
  1803				continue
  1804			}
  1805			if strings.HasPrefix(line, "# ") {
  1806				title = strings.TrimSpace(line[2:])
  1807				break
  1808			}
  1809			// 非标题行，用作兜底标题
  1810			title = line
  1811			break
  1812		}
  1813	
  1814		if title == "" {
  1815			logger.Warn("ensureWenyanTitle: 无法从正文提取标题",
  1816				zap.Int("content_len", len(content)),
  1817				zap.Bool("has_frontmatter", hasFrontmatter))
  1818			return args
  1819		}
  1820	
  1821		// 注入 title
  1822		var newContent string
  1823		if hasFrontmatter {
  1824			// 已有 frontmatter 但缺 title：在 frontmatter 内部插入 title 行
  1825			// content = "---\n...existing fields...\n---\n正文"
  1826			// 在第一个 "---\n" 之后插入 "title: xxx\n"
  1827			newContent = "---\ntitle: " + title + "\n" + content[4:] // content[4:] 跳过开头的 "---\n"
  1828		} else {
  1829			// 无 frontmatter：在前面加新的 frontmatter block
  1830			newContent = fmt.Sprintf("---\ntitle: %s\n---\n\n%s", title, content)
  1831		}
  1832		m["content"] = newContent
  1833		out, err := json.Marshal(m)
  1834		if err != nil {
  1835			logger.Warn("ensureWenyanTitle: 序列化失败，保留原始参数",
  1836				zap.Error(err))
  1837			return args
  1838		}
  1839		logger.Info("ensureWenyanTitle: 自动注入 frontmatter title",
  1840			zap.String("title", title))
  1841		return out
  1842	}
