    20	
    21	// StreamingExecutor 边收边执行，按并发安全策略调度。
    22	type StreamingExecutor struct {
    23		mu          sync.Mutex
    24		toolDef     map[string]*mcphost.ToolDefinition
    25		executor    ToolExecutorFunc
