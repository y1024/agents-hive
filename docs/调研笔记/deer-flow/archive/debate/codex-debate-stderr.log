    50		toolPolicy    *skills.ToolPolicy   // 工具策略引擎（可选，用于 group/profile 展开和 subagent deny）
    51	
    52		dynamicAgents map[string]map[string]*BaseAgent // sessionID -> agentID -> agent（per-session 隔离）
