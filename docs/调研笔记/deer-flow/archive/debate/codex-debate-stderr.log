   172	// tryScheduleUnsafeLocked 尝试调度下一个 unsafe 工具。
   173	// 调用方必须持有 se.mu。
   174	// unsafeCount 在调度时立即递增（持有锁），不在 goroutine 内递增，消除竞态窗口。
   175	func (se *StreamingExecutor) tryScheduleUnsafeLocked() {
   176		if se.unsafeCount > 0 || len(se.unsafeQueue) == 0 {
   177			return
   178		}
   179		next := se.unsafeQueue[0]
   180		se.unsafeQueue = se.unsafeQueue[1:]
   181		se.unsafeCount++ // 持有锁时递增，消除 goroutine 启动前的竞态窗口
   182		go se.runTool(next)
   183	}
