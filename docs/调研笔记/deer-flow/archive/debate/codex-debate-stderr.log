    10	
    11	// emitDualDiff 打 MetricDualDiffTotal{differs}（task 10.5）。
    12	//
    13	// 语义：只在 mode=dual 才 emit——mode=legacy/spec 调用此函数是契约违约（不会发生，
    14	// 但防御性不做 no-op，caller 负责按 mode 分流；测试会捕获误 emit）。
    15	//
    16	//   - differs=DualDiffAgree（"false"）：spec 路径成功（decision.Path == PathDual），
    17	//     operators 读此 counter 认知到本轮 dual 真正双跑，spec 观点可见。
    18	//   - differs=DualDiffDiffer（"true"）：spec 路径失败，decision 被 downshift 到 PathLegacy；
    19	//     dual 实质退化成 legacy，用于估算 dual rollout 健康度。
    20	//
    21	// 蓝军 mutation 点位：
    22	//   - R1 改 Name 常量 → Name 断言红
    23	//   - R2 删 enqueue 调用 → drainMetric 超时红
    24	//   - R3 label key "differs" 改名 → Labels 断言红
    25	//   - R4 label 值写反（Agree/Differ 对调）→ scenario 交叉断言红
    26	func (m *Master) emitDualDiff(differs specdriven.DualDiffLabel) {
    27		m.enqueueMetric(observability.Metric{
    28			Name:  specdriven.MetricDualDiffTotal,
    29			Value: 1,
    30			Labels: map[string]any{
    31				"differs": string(differs),
    32			},
    33			Ts: time.Now(),
    34		})
    35	}
    36	
    37	// emitSpecFallback 打 MetricSpecFallbackTotal{reason}（task 10.6）。
    38	//
    39	// 语义：只在 mode=spec AND specErr != nil 时 emit。与 plan_fallback_total 的区别：
    40	//   - plan_fallback_total 覆盖所有 non-legacy mode（dual 也算）；
    41	//   - spec_fallback_total 只计 primary-spec 失败——对应 operators"用户体验到了 fallback"
    42	//     的那条 SLO 分子（docs/runbooks/spec-driven-rollout.md §SLO 门槛 ≤ 5%）。
    43	//
    44	// reason 来自 PlanFallbackReason 白名单——复用 classifyPlannerErr 的分类，
    45	// 避免 enum 双写分歧（同一 err 在两个 metric 上应映射到同 reason）。
    46	//
    47	// 蓝军 mutation 点位：
    48	//   - R1 改 Name 常量 → Name 断言红
    49	//   - R2 label key "reason" 改名 → Labels 断言红
    50	//   - R3 删 enqueue 调用 → drainMetric 超时红
    51	//   - R4 写死 label 值 → scenario 交叉断言红
    52	func (m *Master) emitSpecFallback(reason specdriven.PlanFallbackReason) {
    53		m.enqueueMetric(observability.Metric{
    54			Name:  specdriven.MetricSpecFallbackTotal,
    55			Value: 1,
    56			Labels: map[string]any{
    57				"reason": string(reason),
    58			},
    59			Ts: time.Now(),
    60		})
    61	}
    62	
    63	// emitExecutionPath 计每次 ingress 实际走的执行路径，label=path（Round 5 G2）。
    64	// 与 emitIntakeMetric 互补：后者按"决策结果"打，前者按"实际路由"打——
    65	// 在 spec_runner 接入完整后两者应一致；分歧即指 routing bug。
    66	func (m *Master) emitExecutionPath(path intake.Path) {
    67		m.enqueueMetric(observability.Metric{
    68			Name:  specdriven.MetricExecutionPathTotal,
    69			Value: 1,
    70			Labels: map[string]any{
    71				"path": string(path),
    72			},
    73			Ts: time.Now(),
    74		})
    75	}
    76	
    77	// emitDispatchMetrics 在 applySpecDrivenIntake decision 得出后按 mode 分流打 10.5/10.6
    78	// 的两个 counter。独立函数是为了 caller 可读性 + 单测 surface（fake Master 直接喂
    79	// mode + decision + err 组合，不必重走整条 applySpecDrivenIntake）。
    80	//
    81	// 语义分流表（mode × decision.Path × err）：
    82	//
    83	//	mode=dual  × path=PathDual   × err=nil   → DualDiff(Agree)
    84	//	mode=dual  × path=PathLegacy × err!=nil  → DualDiff(Differ)
    85	//	mode=dual  × path=PathLegacy × err=nil   → DualDiff(Differ)   // 罕见：ResolveIntakeDecision 降级但无 err
    86	//	mode=spec  × path=PathLegacy × err!=nil  → SpecFallback(reason=classifyPlannerErr)
    87	//	mode=spec  × path=PathSpec   × err=nil   → 不 emit（primary 成功，无 fallback）
    88	//	mode=legacy × any                        → 不 emit（本函数不会被 legacy 路径调用）
    89	//
    90	// 蓝军 mutation 点位：
    91	//   - R1 把 mode=dual / mode=spec 判断删掉（都 emit）→ legacy 路径断言红
    92	//   - R2 differs 判断反转（err=nil → Differ）→ Agree 场景断言红
    93	//   - R3 SpecFallback reason 写死 → 交叉 case 断言红
    94	func (m *Master) emitDispatchMetrics(mode intake.Mode, decision intake.IntakeDecision, specErr error) {
    95		switch mode {
    96		case intake.ModeDual:
    97			if decision.Path == intake.PathDual && specErr == nil {
    98				m.emitDualDiff(specdriven.DualDiffAgree)
    99				return
   100			}
   101			// dual 下被降级到 legacy（或 err != nil）→ differs=true
   102			m.emitDualDiff(specdriven.DualDiffDiffer)
   103		case intake.ModeSpec:
   104			if specErr != nil {
   105				m.emitSpecFallback(m.classifyPlannerErr(specErr))
   106			}
   107			// primary-spec 成功则不 emit——spec_fallback 是"发生 fallback"的 counter，
   108			// 不是"spec path 次数"的 counter（后者由 intake_decision_total 承担）。
   109		default:
   110			// mode=legacy 或 mode 非法——caller 契约是只在 mode=dual/spec 才调本函数。
   111			// 不 emit，让 contract 测试捕获违约。
   112		}
   113	}
