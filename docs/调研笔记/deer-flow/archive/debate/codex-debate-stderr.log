   123	// shouldSkipJSONMode 判断是否应跳过 JSON mode。
   124	//
   125	// 决策优先级：
   126	// 1. 显式配置 disableJSONMode = true → 跳过
   127	// 2. 缓存中标记该 BaseURL 不支持 → 跳过
   128	// 3. 其他情况 → 不跳过
   129	func (c *Client) shouldSkipJSONMode() bool {
   130		// 优先检查显式配置
   131		if c.disableJSONMode {
   132			return true
   133		}
   134	
   135		// 查询缓存（BaseURL 为空时不检查）
   136		if c.baseURL == "" {
   137			return false
   138		}
   139	
   140		if markedAt, ok := unsupportedJSONModeCache.Load(c.baseURL); ok {
   141			// 检查 TTL，过期则清除
   142			if t, ok := markedAt.(time.Time); ok && time.Since(t) < jsonModeCacheTTL {
   143				return true
   144			}
   145			unsupportedJSONModeCache.Delete(c.baseURL)
   146		}
   147		return false
   148	}
