    39	// EventBus 管理 WebSocket 广播订阅和消息分发。
    40	//
    41	// 生命周期：
    42	//   - NewEventBus 创建 → Broadcast/Subscribe 正常使用 → Close 优雅关停。
    43	//   - Close 后所有 Broadcast 和 Subscribe 操作被静默忽略，不会 panic。
    44	//   - Close 会等待所有后台重试 goroutine 结束，确保 logger 不被悬空使用。
    45	//
    46	// 分发策略：
    47	//   - Broadcast 始终非阻塞：对所有事件先尝试非阻塞写入通道。
    48	//   - 非关键事件：通道满时直接丢弃并统计。
    49	//   - 关键事件：通道满时启动独立后台 goroutine 异步重试（最多等待 criticalEventTimeout），
    50	//     Broadcast 本身立即返回，RLock 迅速释放，不再有 N×5s 串行阻塞。
    51	//
    52	// 死订阅者清理：
    53	//   - 每次非阻塞发送失败（通道满）都会递增该订阅者的连续丢弃计数器。
    54	//   - 发送成功时重置计数器。
    55	//   - 连续丢弃超过 deadSubscriberThreshold 次时标记为死订阅者。
    56	//   - 调用 PruneDeadSubscribers 可将死订阅者从 map 中清除。
    57	//
    58	// 锁层次（严格有序，防止死锁）：
    59	//
    60	//	mu（订阅者 map） → dropsMu（丢弃计数 map）
    61	type EventBus struct {
    62		subs       map[uint64]chan BroadcastMessage // 订阅者通道
    63		subCounter uint64                           // 订阅者 ID 计数器（原子操作）
    64		mu         sync.RWMutex                     // 保护 subs map
    65	
    66		// consecutiveDrops 记录每个订阅者的连续丢弃次数，用于死订阅者检测。
    67		// Broadcast 持有 mu.RLock 期间并发写此 map，故需独立锁保护。
    68		consecutiveDrops map[uint64]int
    69		dropsMu          sync.Mutex // 专门保护 consecutiveDrops
    70	
    71		logger *zap.Logger
    72	
    73		// droppedTotal 累计丢弃数量（含关键事件异步重试最终失败的情况）
    74		droppedTotal atomic.Int64
    75	
    76		// onDrop 消息丢弃回调（可选，用于可观测性埋点）
    77		onDrop func(msgType string, total int64)
    78	
    79		// retryWg 追踪所有后台 retryCriticalSend goroutine，
    80		// 供 Close/WaitRetries 等待全部完成。
    81		retryWg sync.WaitGroup
    82	
    83		// closeCh 在 Close() 时关闭，通知所有 retryCriticalSend goroutine 立即退出。
    84		// 这比等待 criticalEventTimeout 自然超时快得多，实现亚毫秒级关停。
    85		closeCh chan struct{}
    86	
    87		// closed 标记 EventBus 是否已关闭（原子操作，无锁快速路径检查）。
    88		closed atomic.Bool
    89	
    90		// closeOnce 保证 Close 只执行一次。
    91		closeOnce sync.Once
    92	}
    93	
    94	// NewEventBus 创建新的事件总线。
    95	// 调用方在不再需要时必须调用 Close() 以释放后台 goroutine 资源。
    96	func NewEventBus(logger *zap.Logger) *EventBus {
    97		return &EventBus{
    98			subs:             make(map[uint64]chan BroadcastMessage),
    99			consecutiveDrops: make(map[uint64]int),
   100			closeCh:          make(chan struct{}),
   101			logger:           logger,
   102		}
   103	}
   104	
   105	// SetOnDrop 设置消息丢弃回调（用于可观测性埋点）。
   106	// 回调参数：msgType 为被丢弃的消息类型，total 为累计丢弃总数。
   107	func (eb *EventBus) SetOnDrop(fn func(msgType string, total int64)) {
   108		eb.onDrop = fn
   109	}
   110	
   111	// Subscribe 创建一个 WebSocket 广播订阅，返回订阅 ID 和消息通道。
   112	// 通道容量为 subscriberBufferSize，以减少正常负载下的丢弃可能。
   113	// 若 EventBus 已关闭，返回 (0, nil)。
   114	func (eb *EventBus) Subscribe() (uint64, chan BroadcastMessage) {
   115		if eb.closed.Load() {
   116			return 0, nil
   117		}
   118	
   119		ch := make(chan BroadcastMessage, subscriberBufferSize)
   120		subID := atomic.AddUint64(&eb.subCounter, 1)
   121	
   122		eb.mu.Lock()
   123		eb.subs[subID] = ch
   124		eb.mu.Unlock()
   125	
   126		eb.dropsMu.Lock()
   127		eb.consecutiveDrops[subID] = 0
   128		eb.dropsMu.Unlock()
   129	
   130		eb.logger.Debug("WebSocket 订阅已创建", zap.Uint64("sub_id", subID))
   131		return subID, ch
   132	}
   133	
   134	// Unsubscribe 取消 WebSocket 广播订阅并关闭对应通道。
   135	func (eb *EventBus) Unsubscribe(subID uint64) {
   136		eb.mu.Lock()
   137		if ch, exists := eb.subs[subID]; exists {
   138			close(ch)
   139			delete(eb.subs, subID)
   140		}
   141		eb.mu.Unlock()
   142	
   143		eb.dropsMu.Lock()
   144		delete(eb.consecutiveDrops, subID)
   145		eb.dropsMu.Unlock()
   146	
   147		eb.logger.Debug("WebSocket 订阅已取消", zap.Uint64("sub_id", subID))
   148	}
   149	
   150	// Broadcast 向所有订阅者广播消息。
   151	//
   152	// 核心修复：Broadcast 全程持有 RLock，但对每个订阅者的写操作只做非阻塞 select。
   153	//   - 通道有空间：直接写入，立即返回。
   154	//   - 通道已满 + 关键事件：启动后台 goroutine 异步重试，Broadcast 不等待。
   155	//   - 通道已满 + 非关键事件：丢弃并统计。
   156	//
   157	// 这样无论订阅者多慢，Broadcast 都在 O(N) 次非阻塞操作后返回，
   158	// 彻底消除了原来最坏 5*N 秒的串行阻塞。
   159	func (eb *EventBus) Broadcast(msg BroadcastMessage) {
   160		if eb.closed.Load() {
   161			return
   162		}
   163	
   164		eb.mu.RLock()
   165		defer eb.mu.RUnlock()
   166	
   167		if len(eb.subs) == 0 {
   168			return
   169		}
   170	
   171		eb.logger.Debug("广播消息到 WebSocket 订阅者",
   172			zap.String("type", msg.Type),
   173			zap.Int("subscriber_count", len(eb.subs)),
   174		)
   175	
   176		critical := isCriticalEvent(msg.Type)
   177	
   178		for subID, ch := range eb.subs {
   179			select {
   180			case ch <- msg:
   181				// 非阻塞写入成功，重置连续丢弃计数器
   182				eb.dropsMu.Lock()
   183				eb.consecutiveDrops[subID] = 0
   184				eb.dropsMu.Unlock()
   185			default:
   186				// 通道已满
   187				if critical {
   188					// 关键事件：后台异步重试，不阻塞 Broadcast 主路径
   189					eb.retryWg.Add(1)
   190					go func(sid uint64, c chan BroadcastMessage, m BroadcastMessage) {
   191						defer eb.retryWg.Done()
   192						eb.retryCriticalSend(sid, c, m)
   193					}(subID, ch, msg)
   194				} else {
   195					// 非关键事件：直接丢弃，并更新连续丢弃计数
   196					eb.dropsMu.Lock()
   197					drops := eb.consecutiveDrops[subID] + 1
   198					eb.consecutiveDrops[subID] = drops
   199					eb.dropsMu.Unlock()
   200	
   201					total := eb.droppedTotal.Add(1)
   202					if eb.onDrop != nil {
   203						eb.onDrop(msg.Type, total)
   204					}
   205					eb.logger.Warn("WebSocket 订阅者通道已满，丢弃非关键消息",
   206						zap.Uint64("sub_id", subID),
   207						zap.String("msg_type", msg.Type),
   208						zap.Int("consecutive_drops", drops),
   209						zap.Int64("total_dropped", total),
   210					)
   211				}
   212			}
   213		}
   214	}
   215	
   216	// retryCriticalSend 在独立 goroutine 中异步重试发送关键事件。
   217	//
   218	// 它在 criticalEventTimeout 内持续尝试将消息写入订阅者通道：
   219	//   - 成功：记录 Debug 日志。
   220	//   - 超时：记录 Warn 日志并计入 droppedTotal，表明该订阅者消费严重滞后。
   221	//
   222	// 注意：此函数运行时不持有任何锁，通道生命周期由 Unsubscribe 负责关闭。
   223	// 向已关闭通道发送会 panic，故使用 recover 捕获。
   224	func (eb *EventBus) retryCriticalSend(subID uint64, ch chan BroadcastMessage, msg BroadcastMessage) {
   225		// 捕获向已关闭通道写入时的 panic（订阅者在重试期间取消订阅）
