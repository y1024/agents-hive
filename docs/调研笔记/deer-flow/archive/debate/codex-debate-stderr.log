    46	}
    47	
    48	// closeDone 安全关闭 Done channel，通过 sync.Once 防止 double-close panic。
    49	func (t *TrackedTool) closeDone() {
    50		t.closeOnce.Do(func() { close(t.Done) })
    51	}
