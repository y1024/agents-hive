     7	// logSpecCtxAtReactEntry 把当前 session 挂的 specCtx 读出来打诊断日志（task 4.4）。
     8	//
     9	// 设计契约：
    10	//   - 读侧严格 atomic.Pointer.Load()（SessionState.LoadSpecCtx），不持任何锁。
    11	//     Codex P0-6 红线：runReActLoop 外层已持会话锁，这里再引入互斥 getter 会死锁。
    12	//   - specCtx == nil 等价于"本 session 非 spec-driven（或 intake 已 fail-closed 清零）"，
    13	//     打一行 "none" 日志便于 grep 诊断，绝不 panic。
    14	//   - 非 nil 时打 change_id / current_task_key / revision 三字段——足够在生产排查
    15	//     "为什么这个 session 没走 spec"时快速对齐，又不膨胀到把整个 Plan.Steps dump。
    16	//
    17	// 为什么不 emit metric：task 4.4 只要求"读 specCtx"证明 plumbing 到达 react 层；
    18	// 加 metric 会改 Prom 契约（新 series），归 Sprint 3.3.e smoke 阶段再决定。
    19	//
    20	// 蓝军 mutation 点位：
    21	//   - 去掉 LoadSpecCtx 调用 → TestLogSpecCtxAtReactEntry_WithCtx change_id 断言红
    22	//   - 改 nil 分支打 present=true → _NilSession / _NoSpecCtx 断言红
    23	func logSpecCtxAtReactEntry(logger *zap.Logger, session *SessionState) {
    24		if logger == nil {
    25			return
    26		}
    27		if session == nil {
    28			logger.Debug("specdriven.react_entry specCtx=none",
    29				zap.Bool("present", false),
    30				zap.String("reason", "nil_session"),
    31			)
    32			return
    33		}
    34		ctx := session.LoadSpecCtx()
    35		if ctx == nil {
    36			logger.Debug("specdriven.react_entry specCtx=none",
    37				zap.Bool("present", false),
    38				zap.String("session_id", session.ID),
    39			)
    40			return
    41		}
    42		logger.Debug("specdriven.react_entry specCtx=present",
    43			zap.Bool("present", true),
    44			zap.String("session_id", session.ID),
    45			zap.String("change_id", ctx.ChangeID),
    46			zap.String("current_task_key", ctx.CurrentTaskKey),
    47			zap.Int("revision", ctx.Revision),
    48		)
    49	}

