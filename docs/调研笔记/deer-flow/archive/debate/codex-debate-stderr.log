   128		se.mu.Lock()
   129		defer se.mu.Unlock()
   130	
   131		if !tool.IsSafe {
   132			se.unsafeCount--
   133			se.tryScheduleUnsafeLocked()
   134		}
   135	
   136		if tool.Aborted {
   137			return
   138		}
   139	
   140		tool.Result = result
   141		if err != nil {
   142			tool.Result = &mcphost.ToolResult{
   143				Content: content(fmt.Sprintf("execution error: %v", err)),
