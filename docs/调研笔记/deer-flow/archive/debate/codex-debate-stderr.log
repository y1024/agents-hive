    21	// chatViaResponses 通过 Responses API 实现 Chat 调用。
    22	func (c *Client) chatViaResponses(ctx context.Context, req ChatRequest) (*ChatResponse, error) {
    23		snapModel, _, _ := c.snapshot()
    24	
    25		// JSON mode fallback prompt
    26		const jsonFallbackSuffix = "\n\nCRITICAL: 你必须只返回有效的 JSON。不要在 JSON 对象之前或之后包含任何文本。格式示例: {\"key\": \"value\", ...}"
    27	
    28		systemPrompt := req.SystemPrompt
    29		shouldSkip := req.JSONMode && c.shouldSkipJSONMode()
    30		if shouldSkip {
    31			systemPrompt += jsonFallbackSuffix
    32		}
    33	
    34		// 构建 input items
    35		input := buildResponsesInput(req.Messages)
    36	
    37		params := responses.ResponseNewParams{
    38			Model: snapModel,
    39			Input: responses.ResponseNewParamsInputUnion{
    40				OfInputItemList: input,
    41			},
    42		}
    43	
    44		// 系统提示 → Instructions
    45		if systemPrompt != "" {
    46			params.Instructions = param.NewOpt(systemPrompt)
    47		}
    48	
    49		if req.Temperature > 0 {
    50			params.Temperature = param.NewOpt(req.Temperature)
    51		}
    52		if req.MaxTokens > 0 {
    53			params.MaxOutputTokens = param.NewOpt(req.MaxTokens)
    54		}
    55	
    56		// JSON mode → text.format
    57		if req.JSONMode && !shouldSkip {
    58			params.Text = responses.ResponseTextConfigParam{
    59				Format: responses.ResponseFormatTextConfigUnionParam{
    60					OfJSONObject: &shared.ResponseFormatJSONObjectParam{},
    61				},
    62			}
    63		}
    64	
    65		// 客户端级别 reasoning effort
    66		if c.reasoningEffort != "" {
    67			params.Reasoning = shared.ReasoningParam{
    68				Effort: shared.ReasoningEffort(c.reasoningEffort),
    69			}
    70		}
    71	
    72		// 用流式请求替代非流式，避免中转站对非流式请求的限流
    73		content, finishReason, usage, err := c.responsesStreamCollect(ctx, params)
    74		if err != nil {
    75			// 自动回退：如果 JSON mode 失败，去掉 JSON format 重试
    76			if req.JSONMode && !shouldSkip && isResponseFormatError(err) {
    77				c.markJSONModeUnsupported()
    78				params.Text = responses.ResponseTextConfigParam{}
    79				if req.SystemPrompt != "" {
    80					params.Instructions = param.NewOpt(req.SystemPrompt + jsonFallbackSuffix)
    81				}
    82				content, finishReason, usage, err = c.responsesStreamCollect(ctx, params)
    83			}
    84			if err != nil {
    85				c.logAPIError(err, "responses_chat")
    86				return nil, errs.Wrap(errs.CodeLLMError, "Responses API 调用失败", err)
    87			}
    88		}
    89	
    90		return &ChatResponse{
    91			Content:      content,
    92			FinishReason: finishReason,
    93			Usage:        usage,
    94		}, nil
    95	}
    96	
    97	// responsesStreamCollect 用 NewStreaming 发送请求并把 SSE 事件累积成完整响应。
    98	// 这样所有 Responses API 调用都走流式端点，避免中转站对非流式请求的限流（429）。
    99	func (c *Client) responsesStreamCollect(ctx context.Context, params responses.ResponseNewParams) (content, finishReason string, usage Usage, err error) {
   100		doAttempt := func() error {
   101			stream := c.client.Responses.NewStreaming(ctx, params)
   102			defer stream.Close()
   103	
   104			// 每次尝试前重置所有输出变量，防止重试时混入上次部分写入的脏数据
   105			var localContent, localFinishReason string
   106			var localUsage Usage
   107			for stream.Next() {
   108				event := stream.Current()
   109				switch variant := event.AsAny().(type) {
   110				case responses.ResponseTextDeltaEvent:
   111					localContent += variant.Delta
   112				case responses.ResponseCompletedEvent:
   113					localFinishReason = extractResponsesFinishReason(&variant.Response)
   114					localUsage = convertResponsesUsage(&variant.Response)
   115				}
   116			}
   117			if err := stream.Err(); err != nil {
   118				return err
   119			}
   120			// 仅在成功时写入外部变量
   121			content = localContent
   122			finishReason = localFinishReason
   123			usage = localUsage
   124			return nil
   125		}
   126	
   127		_, err = resilience.Do(ctx, llmRetryPolicy, c.logger, "responses_stream_collect", func() (struct{}, error) {
   128			return struct{}{}, doAttempt()
   129		})
   130		return
   131	}
